		Если Объект.ВидСделки = Перечисления.ВидыСделок.Продажа Тогда
			РассчитатьПрибыльВСтроке(СтрокаТ);
		КонецЕсли;

	КонецЦикла;

	Если ЗначениеЗаполнено(Объект.ВалютаСделки) И НЕ ЗначениеЗаполнено(Объект.КурсСделки) Тогда

		УстановкаКурсаВалюты();

	КонецЕсли;

	Если Объект.Позиции.Количество() > 0 Тогда

		ВывестиОстатки();

	КонецЕсли;


