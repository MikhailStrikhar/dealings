&НаСервере
Процедура ПозицииИнструментПриИзмененииНаСервере(ИдентификаторТекущейСтроки)

	СтрокаТ = Объект.Позиции.НайтиПоИдентификатору(ИдентификаторТекущейСтроки);
	РеквизитыИнструмента = ЗначенияРеквизитовОбъекта(СтрокаТ.Инструмент, "РазмерЛота, ВалютаНоминала");
	СтрокаТ.РазмерЛота = РеквизитыИнструмента.РазмерЛота;
	Если НЕ ЗначениеЗаполнено(Объект.ВалютаСделки) Тогда
		//ЗаполнитьВалютуПоИнструменту(Элементы.Позиции.ТекущиеДанные.Инструмент);
		Объект.ВалютаСделки = РеквизитыИнструмента.ВалютаНоминала;
		УстановкаКурсаВалюты();
	ИначеЕсли Объект.ВалютаСделки <> РеквизитыИнструмента.ВалютаНоминала Тогда
		ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Отличается валюта сделки (%1) и валюта номинала (%2) инструмента %3",
				Объект.ВалютаСделки, РеквизитыИнструмента.ВалютаНоминала, СтрокаТ.Инструмент), , "ВалютаСделки");
	КонецЕсли;

	//ЗначенияРеквизитовОбъекта = ЗначенияРеквизитовОбъекта(СтрокаТ.Инструмент, "РазмерЛота, ВалютаНоминала");
	//СтрокаТ.РазмерЛота = ЗначенияРеквизитовОбъекта.РазмерЛота;
	//	СтрокаТ.ВалютаСделки = ЗначенияРеквизитовОбъекта.ВалютаНоминала;

КонецПроцедуры

&НаКлиенте
Процедура ПозицииИнструментПриИзменении(Элемент)

	ИдентификаторТекущейСтроки = Элементы.Позиции.ТекущиеДанные.ПолучитьИдентификатор();
	ПозицииИнструментПриИзмененииНаСервере(ИдентификаторТекущейСтроки);

КонецПроцедуры

&НаСервере
Процедура УстановкаКурсаВалюты()

	Объект.КурсСделки = РасчетыВДокументах.КурсВалютыНаДату(Объект.Дата, Объект.ВалютаСделки);

КонецПроцедуры

&НаСервере
Процедура ПроверитьВалютуВСтроках(Отказ)

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Инструменты.Ссылка КАК Инструмент,
		|	Инструменты.ВалютаНоминала КАК ВалютаНоминала
		|ИЗ
		|	Справочник.Инструменты КАК Инструменты
		|ГДЕ
		|	Инструменты.Ссылка В(&Инструменты)
		|	И Инструменты.ВалютаНоминала <> &ВалютаСделки";

	Запрос.УстановитьПараметр("Инструменты", Объект.Позиции.Выгрузить( , "Инструмент").ВыгрузитьКолонку("Инструмент"));
	Запрос.УстановитьПараметр("ВалютаСделки", Объект.ВалютаСделки);
	РезультатЗапроса = Запрос.Выполнить();

	Выборка = РезультатЗапроса.Выбрать();

	Пока Выборка.Следующий() Цикл
		ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Отличается валюта сделки (%1) и валюта номинала (%2) инструмента %3",
				Объект.ВалютаСделки, Выборка.ВалютаНоминала, Выборка.Инструмент), , "ВалютаСделки", , Отказ);
	КонецЦикла;

КонецПроцедуры

