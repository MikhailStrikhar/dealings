&НаСервере
Процедура ЗаполнитьОстатки(ТЧ, Портфель)

	Запрос = Новый Запрос(
			"ВЫБРАТЬ
			|	Значения.Инструмент КАК Инструмент
			|ПОМЕСТИТЬ Значения
			|ИЗ
			|	&ТЧ КАК Значения
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	Значения.Инструмент КАК Инструмент,
			|	СпрИнструменты.РазмерЛота КАК РазмерЛота,
			|	ЕСТЬNULL(ПозицииИнструментов.КоличествоОстаток, 0) / СпрИнструменты.РазмерЛота КАК Остаток
			|ИЗ
			|	Значения КАК Значения
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ПозицииИнструментов.Остатки(
			|				,
			|				(Портфель, Инструмент) В
			|					(ВЫБРАТЬ
			|						&Портфель,
			|						Значения.Инструмент
			|					ИЗ
			|						Значения КАК Значения)) КАК ПозицииИнструментов
			|		ПО (ПозицииИнструментов.Инструмент = Значения.Инструмент)
			|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Инструменты КАК СпрИнструменты
			|		ПО Значения.Инструмент = СпрИнструменты.Ссылка");

	//Запрос.УстановитьПараметр("Инструменты", ТЧ.Выгрузить(, "Инструмент").ВыгрузитьКолонку("Инструмент"));
	Запрос.УстановитьПараметр("ТЧ", ТЧ.Выгрузить( , "Инструмент"));
	Запрос.УстановитьПараметр("Портфель", Портфель);

	Остатки = Запрос.Выполнить().Выгрузить();
	Остатки.Индексы.Добавить("Инструмент");

	Для Каждого СтрокаТЧ Из ТЧ Цикл
		Отбор = Новый Структура("Инструмент", СтрокаТЧ.Инструмент);
		СтрокаОстатки = Остатки.НайтиСтроки(Отбор);
		Если СтрокаОстатки.Количество() Тогда
			СтрокаОстатков = СтрокаОстатки[0];
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаОстатков, "Остаток, РазмерЛота");
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры // ЗаполнитьОстатки()

&НаСервере
Процедура ПозицииКоличествоПриИзмененииНаСервере(ИдентификаторТекущейСтроки)

	СтрокаТ = Объект.Позиции.НайтиПоИдентификатору(ИдентификаторТекущейСтроки);
	//РазмерЛота = ЗначениеРеквизитаОбъекта(СтрокаТ.Инструмент, "Лот");
	СтрокаТ.КоличествоЛотов = СтрокаТ.Количество / СтрокаТ.РазмерЛота;

КонецПроцедуры

