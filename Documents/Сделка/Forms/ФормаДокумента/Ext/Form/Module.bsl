&НаСервере
Процедура РассчитатьПрибыльВСтроке(Знач СтрокаТ = Неопределено, ИдентификаторТекущейСтроки = Неопределено)

	Если СтрокаТ = Неопределено Тогда
		СтрокаТ = Объект.Позиции.НайтиПоИдентификатору(ИдентификаторТекущейСтроки);
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	КурсыВалютСрезПоследних.Курс / КурсыВалютСрезПоследних.Кратность КАК КурсВалюты
		|ПОМЕСТИТЬ втКурсВалюты
		|ИЗ
		|	РегистрСведений.КурсыВалют.СрезПоследних(&Дата, Валюта = &Валюта) КАК КурсыВалютСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА ПозицииИнструментовОстатки.КоличествоОстаток = 0
		|			ТОГДА 0
		|		ИНАЧЕ ПозицииИнструментовОстатки.СтоимостьОстаток / ПозицииИнструментовОстатки.КоличествоОстаток / втКурсВалюты.КурсВалюты
		|	КОНЕЦ КАК СредняяЦена
		|ИЗ
		|	РегистрНакопления.ПозицииИнструментов.Остатки(
		|			&Дата,
		|			Портфель = &Портфель
		|				И Инструмент = &Инструмент) КАК ПозицииИнструментовОстатки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втКурсВалюты КАК втКурсВалюты
		|		ПО (ИСТИНА)";

	Запрос.УстановитьПараметр("Дата", Объект.Дата);
	Запрос.УстановитьПараметр("Инструмент", СтрокаТ.Инструмент);
	Запрос.УстановитьПараметр("Портфель", Объект.Портфель);
	Запрос.УстановитьПараметр("Валюта", Объект.ВалютаСделки);

	РезультатЗапроса = Запрос.Выполнить();

	Выборка = РезультатЗапроса.Выбрать();

	Если Выборка.Следующий() Тогда
		СредняяЦена = Выборка.СредняяЦена;
	Иначе
		Возврат;
	КонецЕсли;

	СтрокаТ.Прибыль = СтрокаТ.Количество * (СтрокаТ.Цена - СредняяЦена) - СтрокаТ.Комиссия;


КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьВычисленияПриИзмененииСтроки()

	ТекущаяСтрока = Элементы.Позиции.ТекущиеДанные;

	РассчитатьСуммуСделкиВСтроке(ТекущаяСтрока);
	Элементы.ПозицииКомиссия.ПодсказкаВвода = Окр(ТекущаяСтрока.СуммаСделки * 0.0004, 2);
	ИдентификаторТекущейСтроки = ТекущаяСтрока.ПолучитьИдентификатор();
	РассчитатьПрибыльВСтроке( , ИдентификаторТекущейСтроки);
	ВывестиОстатки();

КонецПроцедуры // ВыполнитьВычисленияПриИзмененииСтроки()

