
Процедура ОбработкаПроведения(Отказ, Режим)
	
	Движения.ПозицииИнструментов.Записывать = Истина;
	Если (ВидСделки = Перечисления.ВидыСделок.Продажа) <> Шорт Тогда
		
		// Заполнение ВТ Позиции
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
		Запрос.Текст = 
		"ВЫБРАТЬ
//		|	СделкаПозиции.НомерСтроки КАК НомерСтроки,
		|	СделкаПозиции.Инструмент КАК Инструмент,
		|	СделкаПозиции.Количество КАК Количество,
		|	СделкаПозиции.Цена КАК Цена,
	//		|	СделкаПозиции.ВалютаСделки КАК ВалютаСделки,
		|	СделкаПозиции.Комиссия КАК Комиссия
		|ПОМЕСТИТЬ Позиции
		|ИЗ
		|	&Позиции КАК СделкаПозиции
		|;
		|";
		Запрос.УстановитьПараметр("Позиции", Позиции.Выгрузить());
		Запрос.УстановитьПараметр("Период", МоментВремени());
		Запрос.УстановитьПараметр("Счет", Счет);
		Запрос.УстановитьПараметр("Инструмент", Инструмент);
		Запрос.УстановитьПараметр("Количество", Количество);
		Запрос.УстановитьПараметр("Цена", Цена);
		РезультатЗапроса = Запрос.Выполнить();

		Если Не Шорт Тогда
			
			// проверка наличия покупок по инструменту перед продажей
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	Позиции.Инструмент КАК Инструмент,
			|	ЕСТЬNULL(ПозицииИнструментовОбороты.КоличествоПриход, 0) КАК КоличествоПриход
			|ИЗ
			|	Позиции КАК Позиции
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ПозицииИнструментов.Обороты(
			|				,
			|				&Период,
			|				,
			|				Счет = &Счет
			|					И Инструмент В
			|						(ВЫБРАТЬ
			|							Позиции.Инструмент
			|						ИЗ
			|							Позиции)) КАК ПозицииИнструментовОбороты
			|		ПО (&Счет = ПозицииИнструментовОбороты.Счет)
			|			И Позиции.Инструмент = ПозицииИнструментовОбороты.Инструмент
			|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Инструменты КАК Инструменты
			|		ПО Позиции.Инструмент = Инструменты.Ссылка";
			//|
			//|УПОРЯДОЧИТЬ ПО
			//|	Позиции.НомерСтроки";
			
			РезультатЗапроса = Запрос.Выполнить();
			Выборка= РезультатЗапроса.Выбрать();
			Пока Выборка.Следующий() Цикл
				
				Если Выборка.КоличествоПриход = 0 Тогда
					ОбщегоНазначения.СообщитьПользователю(СтрШаблон("По инструменту %1 в портфеле %2 ещё не было покупок!", Выборка.Инструмент, Счет), ЭтотОбъект,,, Отказ);
				КонецЕсли;
				
			КонецЦикла;

			Если Отказ Тогда
				Возврат;
			КонецЕсли;
			
		КонецЕсли;
		
		// Заполнение движений при продаже
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	КурсыВалютСрезПоследних.Курс / КурсыВалютСрезПоследних.Кратность КАК КурсВалюты
		|ПОМЕСТИТЬ втКурсВалюты
		|ИЗ
		|	РегистрСведений.КурсыВалют.СрезПоследних(&Период, Валюта = &Валюта) КАК КурсыВалютСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Позиции.Цена * втКурсВалюты.КурсВалюты КАК ЦенаПродажи,
		|	Позиции.Количество КАК Количество,
		|	Позиции.Комиссия * втКурсВалюты.КурсВалюты КАК Комиссия,
		|	Позиции.Инструмент КАК Инструмент,
		|	ЕСТЬNULL(ПозицииИнструментовОстатки.КоличествоОстаток, 0) КАК КоличествоОстаток,
		|	ЕСТЬNULL(ВЫБОР
		|			КОГДА ПозицииИнструментовОстатки.КоличествоОстаток = 0
		|				ТОГДА 0
		|			ИНАЧЕ ПозицииИнструментовОстатки.СтоимостьОстаток / ПозицииИнструментовОстатки.КоличествоОстаток
		|		КОНЕЦ, 0) КАК СредняяЦена,
		|	ЕСТЬNULL(ПозицииИнструментовОстатки.СтоимостьОстаток, 0) КАК СтоимостьОстаток,
		|	Инструменты.РазмерЛота КАК РазмерЛота
		|ИЗ
		|	Позиции КАК Позиции
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ПозицииИнструментов.Остатки(
		|				&Период,
		|				Счет = &Счет
		|					И Инструмент В
		|						(ВЫБРАТЬ
		|							Позиции.Инструмент
		|						ИЗ
		|							Позиции)) КАК ПозицииИнструментовОстатки
		|		ПО (&Счет = ПозицииИнструментовОстатки.Счет)
		|			И Позиции.Инструмент = ПозицииИнструментовОстатки.Инструмент
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Инструменты КАК Инструменты
		|		ПО Позиции.Инструмент = Инструменты.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втКурсВалюты КАК втКурсВалюты
		|		ПО (ИСТИНА)
		|
		|ДЛЯ ИЗМЕНЕНИЯ
		|	РегистрНакопления.ПозицииИнструментов.Остатки
		|";
		//|УПОРЯДОЧИТЬ ПО
		//|	Позиции.НомерСтроки";
		
		Запрос.УстановитьПараметр("Валюта", ВалютаСделки);
		РезультатЗапроса = Запрос.Выполнить();
		Выборка = РезультатЗапроса.Выбрать();
		
		Движения.ФинансовыеРезультатыПоСделкам.Записывать = Истина;
		СтруктураОстатковПоИнструменту = Новый Структура("КоличествоОстаток, СтоимостьОстаток");
		ОстаткиПоИнструментам = Новый Соответствие;
		Пока Выборка.Следующий() Цикл
			
			ОстатокПоИнструменту = ОстаткиПоИнструментам.Получить(Выборка.Инструмент);
			Если ОстатокПоИнструменту = Неопределено Тогда
				
				ЗаполнитьЗначенияСвойств(СтруктураОстатковПоИнструменту, Выборка);
				ОстаткиПоИнструментам.Вставить(Выборка.Инструмент, СтруктураОстатковПоИнструменту);
				КоличествоОстатокПоИнструменту = Выборка.КоличествоОстаток;
				СтоимостьОстатокПоИнструменту = Выборка.СтоимостьОстаток;
				
			Иначе
			
				КоличествоОстатокПоИнструменту = ОстатокПоИнструменту.КоличествоОстаток;
				СтоимостьОстатокПоИнструменту = ОстатокПоИнструменту.СтоимостьОстаток;
				
			КонецЕсли;
			
			ЭтоЗакрытиеПозиции = (КоличествоОстатокПоИнструменту = Выборка.Количество) Или (КоличествоОстатокПоИнструменту = -Выборка.Количество);
			Движение = Движения.ФинансовыеРезультатыПоСделкам.Добавить();
			Движение.Период = Дата;
			Движение.Счет = Счет;
			Движение.СтратегияСделки = СтратегияСделки;
			Движение.Инструмент = Выборка.Инструмент;
			Если Шорт Тогда
				Движение.Выручка = Выборка.ЦенаПродажи * Выборка.Количество;
				Если ЭтоЗакрытиеПозиции Тогда
					СебестоимостьСписано = СтоимостьОстатокПоИнструменту;
				Иначе
					СебестоимостьСписано = Выборка.СредняяЦена * Выборка.Количество;
				КонецЕсли;
				Движение.Себестоимость = СебестоимостьСписано;
				Движение.ПрибыльУбыток = - Движение.Себестоимость - Движение.Выручка - Выборка.Комиссия;
			Иначе
				Движение.Выручка = Выборка.ЦенаПродажи * Выборка.Количество;
				Если ЭтоЗакрытиеПозиции Тогда
					СебестоимостьСписано = СтоимостьОстатокПоИнструменту;
				Иначе
					СебестоимостьСписано = Выборка.СредняяЦена * Выборка.Количество;
				КонецЕсли;
				Движение.Себестоимость = СебестоимостьСписано;
				Движение.ПрибыльУбыток = Движение.Выручка - Движение.Себестоимость - Выборка.Комиссия;
			КонецЕсли;
			Движение.Комиссия = Выборка.Комиссия;
			
			Движение = Движения.ПозицииИнструментов.Добавить();
			Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
			Движение.Период = Дата;
			Движение.Счет = Счет;
			Движение.Инструмент = Выборка.Инструмент;
			Движение.Количество = ?(Шорт, -Выборка.Количество, Выборка.Количество);
			Если ЭтоЗакрытиеПозиции Тогда
				Движение.Стоимость = СтоимостьОстатокПоИнструменту;
			ИначеЕсли Шорт Тогда
				Движение.Стоимость = Выборка.ЦенаПродажи * -Выборка.Количество;
			Иначе
				Движение.Стоимость = Выборка.СредняяЦена * Выборка.Количество;
			КонецЕсли;
			
			СтруктураОстатковПоИнструменту.КоличествоОстаток = КоличествоОстатокПоИнструменту - Выборка.Количество;
			СтруктураОстатковПоИнструменту.СтоимостьОстаток = СтоимостьОстатокПоИнструменту - СебестоимостьСписано;
			ОстаткиПоИнструментам.Вставить(Выборка.Инструмент, СтруктураОстатковПоИнструменту);
			
//			Если ЭтоЗакрытиеПозиции Тогда
//				
//				Отбор = Новый Структура("Портфель, Инструмент", Портфель, Выборка.Инструмент);
//				СостояниеПозиции = РегистрыСведений.СостояниеПозиции.Выбрать(, Дата, Отбор);
//				ЗакрытыеСделки = РегистрыСведений.ЗакрытыеСделки.СоздатьМенеджерЗаписи();
////				ЗакрытыеСделки.
//				
//			КонецЕсли;
			
		КонецЦикла;
		Движения.Записать();
		
		// контроль остатков
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПозицииИнструментовОстатки.КоличествоОстаток КАК КоличествоОстаток,
		|	ПозицииИнструментовОстатки.Инструмент КАК Инструмент
		|ИЗ
		|	РегистрНакопления.ПозицииИнструментов.Остатки(
		|			&МоментВремени,
		|			Счет = &Счет
		|				И Инструмент В
		|					(ВЫБРАТЬ
		|						Позиции.Инструмент
		|					ИЗ
		|						Позиции)) КАК ПозицииИнструментовОстатки
		|ГДЕ
		|	ПозицииИнструментовОстатки.КоличествоОстаток < 0";
		
		ГраницаКонтроля = Новый Граница(МоментВремени(), ВидГраницы.Включая);
		Запрос.УстановитьПараметр("МоментВремени", ГраницаКонтроля);
		Если Шорт Тогда
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "КоличествоОстаток < 0", "КоличествоОстаток > 0");
		КонецЕсли;
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка= РезультатЗапроса.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			Если Шорт Тогда
				ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Проверьте наличие позиций по инструменту %1", 
					Выборка.Инструмент), ЭтотОбъект,,, Отказ);
			Иначе
				ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Недостаточно количества позиций по инструменту %1. Не хватает %2", 
					Выборка.Инструмент,
					Выборка.КоличествоОстаток), ЭтотОбъект,,, Отказ);
			КонецЕсли;
			
		КонецЦикла;
		
	Иначе // покупка
		
		//Для Каждого ТекСтрокаПозиции Из Позиции Цикл
			Движение = Движения.ПозицииИнструментов.Добавить();
			Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
			Движение.Период = Дата;
			Движение.Счет = Счет;
			Движение.Инструмент = Инструмент;
			РазмерЛота = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Инструмент, "РазмерЛота");
			Если Шорт Тогда
				Движение.Количество = -Количество;
				Движение.Стоимость = (-Количество * Цена + Комиссия) * РасчетыВДокументах.КурсВалютыНаДату(Дата, ВалютаСделки);
			Иначе
				Движение.Количество = Количество;
				Движение.Стоимость = (Количество * Цена + Комиссия) * РасчетыВДокументах.КурсВалютыНаДату(Дата, ВалютаСделки);
			КонецЕсли;
		//КонецЦикла;
		Движения.Записать();
		
