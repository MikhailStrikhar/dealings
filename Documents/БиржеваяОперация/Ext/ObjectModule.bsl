Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.Сделка") Или ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.БиржеваяОперация") Тогда
		// Заполнение шапки
		ВидСделки = ?(ВидСделки = Перечисления.ВидыСделок.Продажа, Перечисления.ВидыСделок.Покупка, Перечисления.ВидыСделок.Продажа);
		Комментарий = ДанныеЗаполнения.Комментарий;
		ВалютаСделки = ДанныеЗаполнения.ВалютаСделки;
		Счет = ДанныеЗаполнения.Счет;
		СтратегияСделки = ДанныеЗаполнения.СтратегияСделки;
		Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.Сделка") Тогда
			Если ДанныеЗаполнения.Позиции.Количество() > 0 Тогда
				
				 ВызватьИсключение "Невозможно создать биржевую операцию. В документе должна быть хотя бы одна строка";
				 
			ИначеЕсли ДанныеЗаполнения.Позиции.Количество() > 1 Тогда
				
				 ВызватьИсключение "Невозможно создать биржевую операцию. В документе должна быть только одна строка";
				
			Иначе
			
				Для Каждого ТекСтрокаПозиции Из ДанныеЗаполнения.Позиции Цикл
					НоваяСтрока = Позиции.Добавить();
					//НоваяСтрока.ВалютаСделкиУдалить = ТекСтрокаПозиции.ВалютаСделки;
					НоваяСтрока.Инструмент = ТекСтрокаПозиции.Инструмент;
					НоваяСтрока.КоличествоЛотов = ТекСтрокаПозиции.КоличествоЛотов;
					НоваяСтрока.Количество = ТекСтрокаПозиции.Количество;
					НоваяСтрока.Комиссия = ТекСтрокаПозиции.Комиссия;
					НоваяСтрока.Цена = ТекСтрокаПозиции.Цена;
				КонецЦикла;
			
			КонецЕсли;
			
		Иначе
			
			Инструмент = ДанныеЗаполнения.Инструмент;
			КоличествоЛотов = ДанныеЗаполнения.КоличествоЛотов;
			Количество = ДанныеЗаполнения.Количество;
			Комиссия = ДанныеЗаполнения.Комиссия;
			Цена = ДанныеЗаполнения.Цена;
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если ПроверитьЗаполнение() = Ложь Тогда
		Отказ = Истина;
	КонецЕсли;
	
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(ЭтотОбъект);
	
	Если ПроверитьДубли() Тогда
		ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Документ с таким идентификатором (%1) и счетом (%2) уже существует!", OperationId, Счет), Ссылка,,, Отказ);
	КонецЕсли;
	
	Описание = "";
	ТЗПозиции = Позиции.Выгрузить(, "Инструмент");
	ТЗПозиции.Свернуть("Инструмент");
	Для Каждого СтрокаТ Из ТЗПозиции Цикл
		Описание = Описание + ?(ПустаяСтрока(Описание), "", ", ") + СтрокаТ.Инструмент;
	КонецЦикла;
	
КонецПроцедуры


