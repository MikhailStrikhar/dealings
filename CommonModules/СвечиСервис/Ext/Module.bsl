#Область ПрограммныйИнтерфейс

Функция ЗагрузитьСвечи(ПараметрыЗагрузки) Экспорт
    
    ПроверитьПараметрыЗагрузкиСвечей(ПараметрыЗагрузки.СписокИнструментов, ПараметрыЗагрузки.ДатаНачала, ПараметрыЗагрузки.ДатаОкончания, ПараметрыЗагрузки.Таймфрейм);
    
    Результат = Новый Структура;
    Результат.Вставить("ВсегоИнструментов", 0);
    Результат.Вставить("ОбработаноУспешно", 0);
    Результат.Вставить("Пропущено", 0);
    Результат.Вставить("Ошибок", 0);
    Результат.Вставить("КоличествоСвечей", 0);
    Результат.Вставить("СреднееКоличествоСвечейНаИнструмент", 0);
    Результат.Вставить("Ошибки", Новый Массив);
    
    Инструменты = ПолучитьИнструментыДляЗагрузки(ПараметрыЗагрузки);
    Результат.ВсегоИнструментов = Инструменты.Количество();
    
    Если Инструменты.Количество() = 0 Тогда
        Возврат Результат;
    КонецЕсли;
    
    Соединение = ИнтеграцияTInvestAPI.TInvest_СоздатьHTTPСоединение();
    
	МинимальнаяДатаСвечи = Неопределено;
	МаксимальнаяДатаСвечи = Неопределено;
	
    Для Каждого Инструмент Из Инструменты Цикл
        
        Попытка
            ПериодЗагрузки = ОпределитьПериодЗагрузкиПоИнструменту(Инструмент, ПараметрыЗагрузки);
            
            Если ПериодЗагрузки = Неопределено Тогда
                Результат.Пропущено = Результат.Пропущено + 1;
                Продолжить;
            КонецЕсли;
            
            КоличествоСвечей = СвечиСервис.ЗагрузитьСвечиПоИнструменту(
                Инструмент,
                ПериодЗагрузки.ДатаНачала,
                ПериодЗагрузки.ДатаОкончания,
                ПараметрыЗагрузки.Таймфрейм,
				Соединение
            );
            
            Результат.ОбработаноУспешно = Результат.ОбработаноУспешно + 1;
            Результат.КоличествоСвечей = Результат.КоличествоСвечей + КоличествоСвечей;
			//МинимальнаяДатаСвечи = Мин(МинимальнаяДатаСвечи, ПериодЗагрузки.ДатаНачала);
			//МаксимальнаяДатаСвечи = Неопределено;
            
        Исключение
            Результат.Ошибок = Результат.Ошибок + 1;
            
            ТекстОшибки = ИнформацияОбОшибке().Описание;
            Результат.Ошибки.Добавить(
                Новый Структура("Инструмент,Ошибка", Инструмент, ТекстОшибки)
            );
        КонецПопытки;
        
    КонецЦикла;
	
	Результат.СреднееКоличествоСвечейНаИнструмент = Результат.КоличествоСвечей / Результат.ВсегоИнструментов;

    Возврат Результат;
    
КонецФункции

// Загружает свечи по инструменту и записывает их в регистр сведений СвечиИнструментов.
// Параметры:
//  Инструмент      - СправочникСсылка.Инструменты
//  ДатаНачала      - Дата
//  ДатаОкончания   - Дата
//  Таймфрейм       - ПеречислениеСсылка.ТаймфреймыСвечей
// Возвращает:
//  Число - количество записанных/обновленных свечей
Функция ЗагрузитьСвечиПоИнструменту(Инструмент, ДатаНачала, ДатаОкончания, Таймфрейм, Соединение) Экспорт
    
    ПроверитьПараметрыЗагрузкиСвечей(Инструмент, ДатаНачала, ДатаОкончания, Таймфрейм);
    
    ИдентификаторИнструмента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Инструмент, "UID");
    ИнтервалAPI = Перечисления.ТаймфреймыСвечей.ПолучитьИнтервалСвечейAPI(Таймфрейм);
    
    МассивСвечейAPI = ИнтеграцияTInvestAPI.ПолучитьСвечи(
        ИдентификаторИнструмента,
        ДатаНачала,
        ДатаОкончания,
        ИнтервалAPI,
		Соединение
    );
    
    Если МассивСвечейAPI = Неопределено Или МассивСвечейAPI.Количество() = 0 Тогда
        Возврат 0;
    КонецЕсли;
    
    ТаблицаСвечей = ПреобразоватьСвечиAPIВТаблицу(Инструмент, Таймфрейм, МассивСвечейAPI);
    КоличествоЗаписей = ЗаписатьСвечиВРегистр(ТаблицаСвечей);
    
    Возврат КоличествоЗаписей;
    
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПроверитьПараметрыЗагрузкиСвечей(Инструмент, ДатаНачала, ДатаОкончания, Таймфрейм)
    
	//Если Инструмент = Неопределено Тогда
	//    ВызватьИсключение "Не задан инструмент.";
	//КонецЕсли;
    
    Если ДатаНачала = Неопределено Тогда
        ВызватьИсключение "Не задана дата начала.";
    КонецЕсли;
    
    Если ДатаОкончания = Неопределено Тогда
        ВызватьИсключение "Не задана дата окончания.";
    КонецЕсли;
    
    Если ДатаНачала > ДатаОкончания Тогда
        ВызватьИсключение "Дата начала больше даты окончания.";
    КонецЕсли;
    
    Если Таймфрейм = Неопределено Тогда
        ВызватьИсключение "Не задан таймфрейм.";
    КонецЕсли;
    
КонецПроцедуры

Функция ПолучитьИнструментыДляЗагрузки(ПараметрыЗагрузки)
    
    ВариантИсточника = ПараметрыЗагрузки.ВариантИсточникаИнструментов;
    
    Если ВариантИсточника = Перечисления.ВариантыИсточникаИнструментов.ТекущиеПозиции Тогда
        Возврат ПолучитьИнструментыИзТекущихПозиций(ПараметрыЗагрузки);
        
	ИначеЕсли ВариантИсточника = Перечисления.ВариантыИсточникаИнструментов.ОдинИнструмент
		Или ВариантИсточника = Перечисления.ВариантыИсточникаИнструментов.СписокИнструментов Тогда
        Возврат ПолучитьОдинИнструментДляЗагрузки(ПараметрыЗагрузки);
        
    КонецЕсли;
    
    ВызватьИсключение "Не реализован вариант источника инструментов: " + Строка(ВариантИсточника);
    
КонецФункции

Функция ПолучитьОдинИнструментДляЗагрузки(ПараметрыЗагрузки)
    
    Результат = Новый Массив;
    
    Если Не ЗначениеЗаполнено(ПараметрыЗагрузки.СписокИнструментов) Тогда
        ВызватьИсключение "Не задан инструмент.";
	ИначеЕсли ТипЗнч(ПараметрыЗагрузки.СписокИнструментов) = Тип("СправочникСсылка.Инструменты") Тогда
	    Результат.Добавить(ПараметрыЗагрузки.СписокИнструментов);
	ИначеЕсли ТипЗнч(ПараметрыЗагрузки.СписокИнструментов) = Тип("Массив") Тогда
	    Результат = ПараметрыЗагрузки.СписокИнструментов;
	ИначеЕсли ТипЗнч(ПараметрыЗагрузки.СписокИнструментов) = Тип("СписокЗначений") Тогда
	    Результат = ПараметрыЗагрузки.СписокИнструментов.ВыгрузитьЗначения();
	Иначе
		ВызватьИсключение "Неожиданный тип параметра";
    КонецЕсли;
    
    Возврат Результат;
    
КонецФункции

Функция ПолучитьИнструментыИзТекущихПозиций(ПараметрыЗагрузки)
	
	УстановитьПривилегированныйРежим(Истина);
	
    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |	Счета.Ссылка КАК Ссылка
    |ПОМЕСТИТЬ втСчета
    |ИЗ
    |	Справочник.Счета КАК Счета
    |ГДЕ
    |	Счета.Платформа = &Платформа
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ РАЗЛИЧНЫЕ
    |	Остатки.Инструмент КАК Инструмент
    |ИЗ
    |	РегистрНакопления.ПозицииИнструментов.Остатки(
    |			,
    |			Счет В
    |				(ВЫБРАТЬ
    |					втСчета.Ссылка КАК Ссылка
    |				ИЗ
    |					втСчета КАК втСчета)) КАК Остатки
    |ГДЕ
    |	Остатки.КоличествоОстаток <> 0";
    
    Запрос.УстановитьПараметр("Платформа", ПараметрыЗагрузки.Платформа);
    
    Если ЗначениеЗаполнено(ПараметрыЗагрузки.Счет) Тогда
        Запрос.УстановитьПараметр("Счет", ПараметрыЗагрузки.Счет);
    Иначе
        Запрос.УстановитьПараметр("Счет", Справочники.Счета.ПустаяСсылка());
    КонецЕсли;
    
    Выборка = Запрос.Выполнить().Выбрать();
    
    Инструменты = Новый Массив;
    Пока Выборка.Следующий() Цикл
        Инструменты.Добавить(Выборка.Инструмент);
    КонецЦикла;
    
    Возврат Инструменты;
    
КонецФункции

Функция ОпределитьПериодЗагрузкиПоИнструменту(Инструмент, ПараметрыЗагрузки)
    
    РежимЗагрузки = ПараметрыЗагрузки.РежимЗагрузки;
    
    Если РежимЗагрузки = Перечисления.РежимыЗагрузкиСвечей.ПолнаяЗагрузка
    	Или РежимЗагрузки = Перечисления.РежимыЗагрузкиСвечей.ПерезагрузкаПериода Тогда
        Возврат Новый Структура("ДатаНачала,ДатаОкончания", ПараметрыЗагрузки.ДатаНачала, ПараметрыЗагрузки.ДатаОкончания);
    КонецЕсли;
    
    Если РежимЗагрузки = Перечисления.РежимыЗагрузкиСвечей.Дозагрузка Тогда
        
        ПоследняяДатаСвечи = ПолучитьПоследнююДатуСвечи(Инструмент, ПараметрыЗагрузки.Таймфрейм);
        
        Если Не ЗначениеЗаполнено(ПоследняяДатаСвечи) Тогда
            ДатаНачала = ПараметрыЗагрузки.ДатаНачала;
        Иначе
            ДатаНачала = ДобавитьШагКДате(ПоследняяДатаСвечи, ПараметрыЗагрузки.Таймфрейм);
        КонецЕсли;
        
        ДатаОкончания = ПараметрыЗагрузки.ДатаОкончания;
        
        Если ДатаНачала > ДатаОкончания Тогда
            Возврат Неопределено;
        КонецЕсли;
        
        Возврат Новый Структура("ДатаНачала ,ДатаОкончания", ДатаНачала, ДатаОкончания);
        
    КонецЕсли;
    
    ВызватьИсключение "Неизвестный режим загрузки: " + Строка(РежимЗагрузки);
    
КонецФункции

Функция ПолучитьПоследнююДатуСвечи(Инструмент, Таймфрейм)
    
    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |   МАКСИМУМ(Свечи.Период) КАК ПоследняяДата
    |ИЗ
    |   РегистрСведений.СвечиИнструментов КАК Свечи
    |ГДЕ
    |   Свечи.Инструмент = &Инструмент
    |   И Свечи.Таймфрейм = &Таймфрейм";
    
    Запрос.УстановитьПараметр("Инструмент", Инструмент);
    Запрос.УстановитьПараметр("Таймфрейм", Таймфрейм);
    
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.ПоследняяДата;
    КонецЕсли;
    
    Возврат Неопределено;
    
КонецФункции

Функция ДобавитьШагКДате(ДатаЗначение, Таймфрейм)
    
    Если Таймфрейм = Перечисления.ТаймфреймыСвечей._Day Тогда
        Возврат НачалоДня(ДатаЗначение + 24 * 60 * 60);
        
    ИначеЕсли Таймфрейм = Перечисления.ТаймфреймыСвечей._1Hour Тогда
        Возврат ДатаЗначение + 60 * 60;
        
    ИначеЕсли Таймфрейм = Перечисления.ТаймфреймыСвечей._15Min Тогда
        Возврат ДатаЗначение + 15 * 60;
        
    ИначеЕсли Таймфрейм = Перечисления.ТаймфреймыСвечей._5Min Тогда
        Возврат ДатаЗначение + 5 * 60;
        
    ИначеЕсли Таймфрейм = Перечисления.ТаймфреймыСвечей._1Min Тогда
        Возврат ДатаЗначение + 60;
    КонецЕсли;
    
    ВызватьИсключение "Неизвестный таймфрейм: " + Строка(Таймфрейм);
    
КонецФункции

