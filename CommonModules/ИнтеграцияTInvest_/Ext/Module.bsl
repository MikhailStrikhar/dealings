Функция docs_dltDELETE(Запрос)
	
	#Если Не ВебКлиент Тогда
		ИмяАлгоритма	= "HTTPCервис_RESTData_docs_dltDELETE";
		ТекстАлгоритма	= глПолучитьТекстАлгоритма(ИмяАлгоритма);
		Если НЕ ПустаяСтрока(ТекстАлгоритма) Тогда
			ПродолжитьВыполнение			= Ложь;
			РезультатВыполненияАлгоритма	= Неопределено;
			Попытка
				Выполнить(ТекстАлгоритма);
			Исключение
				ТекстОшибки = "АЛГОРИТМ '" + ИмяАлгоритма + "':" + СтроковыеФункцииКлиентСервер.ПолучитьПредставлениеОшибки(ИнформацияОбОшибке());
				РегистрацияОшибок.ЗарегистрироватьОшибку(ТекстОшибки, "Критический");
				ВызватьИсключение(ТекстОшибки);
			КонецПопытки;
			Если Не ПродолжитьВыполнение Тогда
				Возврат РезультатВыполненияАлгоритма;
			КонецЕсли;
		КонецЕсли;
	#КонецЕсли
	
	///////////////////////////////////////////////////////////////////
	
	ПараметрыURL 		= Новый СписокЗначений;
	ПараметрыURL.Добавить("methodName");
	ПараметрыЗапроса 	= Новый СписокЗначений;
	ПараметрыЗаголовок 	= Новый СписокЗначений;
	
	Ответ = RestDataСервер.ОбработатьЗапрос(Запрос, "docs_dltDELETE", ПараметрыЗаголовок, ПараметрыURL, ПараметрыЗапроса);
	
	Возврат Ответ;
	
КонецФункции

