Функция TInvest_НайтиИнструмент(СтрокаПоиска, ТипИнструмента = "INSTRUMENT_TYPE_UNSPECIFIED", ТолькоТоргуемые = Истина, Песочница = Ложь) Экспорт

	Если НЕ ЗначениеЗаполнено(СтрокаПоиска) Тогда
		Возврат Неопределено;
	КонецЕсли;

	// Тело запроса
	Тело = Новый Структура;
	Тело.Вставить("query", СтрокаПоиска);
	Тело.Вставить("instrumentKind", ТипИнструмента);
	Тело.Вставить("apiTradeAvailableFlag", ТолькоТоргуемые);

	ТелоJSON = TInvest_СериализоватьВJSON(Тело);
	ПараметрыЗапроса = Новый Структура("Тело", ТелоJSON);

	Данные = TInvest_ВыполнитьЗапрос("POST", "InstrumentsService", "FindInstrument", ПараметрыЗапроса, Ложь);

	Возврат Данные;

КонецФункции

Функция TInvest_ОсновнаяИнформацияОбИнструменте(СтрокаПоиска, КлассКод = "INSTRUMENT_TYPE_UNSPECIFIED", idType = "INSTRUMENT_ID_TYPE_TICKER", ТолькоТоргуемые = Истина, Песочница = Ложь) Экспорт

	// Тело запроса
	Тело = Новый Структура;
	Тело.Вставить("id_type", idType);
	Тело.Вставить("class_code", КлассКод);
	Тело.Вставить("id", СтрокаПоиска);

	ТелоJSON = TInvest_СериализоватьВJSON(Тело);
	ПараметрыЗапроса = Новый Структура("Тело", ТелоJSON);

	Данные = TInvest_ВыполнитьЗапрос("POST", "InstrumentsService", "GetInstrumentBy", ПараметрыЗапроса, Ложь);

	Возврат Данные;

КонецФункции

Процедура ПолучитьПоследниеЦеныПоИнструментам(Знач Инструменты = Неопределено, КоличествоЗаписей) Экспорт

	Если ЗначениеЗаполнено(Инструменты) Тогда
		МассивИдентификаторовИнструментов = Инструменты.ВыгрузитьКолонку("UID");
	Иначе

		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ
			|	Инструменты.UID КАК UID,
			|	Инструменты.Ссылка КАК Ссылка
			|ИЗ
			|	РегистрНакопления.ПозицииИнструментов.Остатки КАК ПозицииИнструментовОстатки
			|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Инструменты КАК Инструменты
			|		ПО ПозицииИнструментовОстатки.Инструмент = Инструменты.Ссылка
			|ГДЕ
			|	Инструменты.UID <> """"";

		Инструменты = Запрос.Выполнить().Выгрузить();
		МассивИдентификаторовИнструментов = Инструменты.ВыгрузитьКолонку("UID");

	КонецЕсли;

	Тело = Новый Структура;
	Тело.Вставить("instrumentId", МассивИдентификаторовИнструментов);
	ТелоJSON = ms_РаботаСREST.TInvest_СериализоватьВJSON(Тело);
	ПараметрыЗапроса = Новый Структура("Тело", ТелоJSON);

	ЦеныПоИнструментам = ms_РаботаСREST.TInvest_ВыполнитьЗапрос("POST", "MarketDataService", "GetLastPrices", ПараметрыЗапроса);

	Если Не ЦеныПоИнструментам.Свойство("lastPrices") Тогда
		Сообщить("Нет данных");
		Возврат;
	КонецЕсли;

	lastPrices = ЦеныПоИнструментам.lastPrices;
	Отбор = Новый Структура("UID");
	Источник = Справочники.ИсточникиДанных.ТИнвест;

	КоличествоЗаписей = 0;
	Для Каждого СтруктураИнструмента Из lastPrices Цикл

		МенеджерЗаписи = РегистрыСведений.ТекущиеЦены.СоздатьМенеджерЗаписи();

		Отбор.UID = СтруктураИнструмента.instrumentUid;
		СтрокиИнструмента = Инструменты.НайтиСтроки(Отбор);
		Если СтрокиИнструмента.Количество() = 1 Тогда
			Инструмент = СтрокиИнструмента[0].Ссылка;
		Иначе
			Сообщить("Не найден инструмент по uid " + СтруктураИнструмента.instrumentUid);
			Продолжить;
		КонецЕсли;
		МенеджерЗаписи.Период = ПреобразоватьСтрокуВДату(Лев(СтруктураИнструмента.time, 19));
		МенеджерЗаписи.Инструмент = Инструмент;
		МенеджерЗаписи.Цена = ЦенаИзКотировки(СтруктураИнструмента.price);
		МенеджерЗаписи.lastPriceType = СтруктураИнструмента.lastPriceType;
		МенеджерЗаписи.Источник = Источник;

		МенеджерЗаписи.Записать();
		КоличествоЗаписей = КоличествоЗаписей + 1;

	КонецЦикла;

КонецПроцедуры

Процедура ПолучитьСчетаПользователя() Экспорт

	Тело = Новый Структура;
	Тело.Вставить("status", "ACCOUNT_STATUS_UNSPECIFIED");
	ТелоJSON = ms_РаботаСREST.TInvest_СериализоватьВJSON(Тело);
	ПараметрыЗапроса = Новый Структура("Тело", ТелоJSON);

	ОтветСервиса = ms_РаботаСREST.TInvest_ВыполнитьЗапрос("POST", "UsersService", "GetAccounts", ПараметрыЗапроса);

	Если Не ОтветСервиса.Свойство("accounts") Тогда
		Сообщить("Нет данных");
		Возврат;
	КонецЕсли;

	accounts = ОтветСервиса.accounts;

	Для Каждого account Из accounts Цикл

		Счет = Справочники.Счета.НайтиПоРеквизиту("AccountId", account.id);
		Если ЗначениеЗаполнено(Счет) Тогда
			ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Найден счет %1 по коду %2", Счет, account.id), Счет);
		Иначе
			Счет = Справочники.Счета.НайтиПоНаименованию(account.name, Истина);
			Если ЗначениеЗаполнено(Счет) Тогда
				ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Найден счет %1 по наименованию %2", Счет, account.name), Счет);
			КонецЕсли;
		КонецЕсли;

		ЕстьИзменения = Ложь;
		Если ЗначениеЗаполнено(Счет) Тогда
			СчетОбъект = Счет.ПолучитьОбъект();
		Иначе
			СчетОбъект = Справочники.Счета.СоздатьЭлемент();
			ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Создан новый счёт %1 (%2)", account.name, account.id), Счет,,, ЕстьИзменения);
		КонецЕсли;

		Если СчетОбъект.Наименование <> account.name Тогда
			СчетОбъект.Наименование = account.name;
			ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Изменено наименование счёта %1 с %2 на %3", Счет, СчетОбъект.Наименование, account.name), Счет,,, ЕстьИзменения);
		КонецЕсли;

		Если СчетОбъект.AccountId <> account.id Тогда
			ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Изменён код счёта %1 с %2 на %3", Счет, СчетОбъект.AccountId, account.id), Счет,,, ЕстьИзменения);
			СчетОбъект.AccountId = account.id;
		КонецЕсли;

		ДатаОткрытия = ПреобразоватьСтрокуВДату(Лев(account.openedDate, 19));
		Если СчетОбъект.ДатаОткрытия <> ДатаОткрытия Тогда
			ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Изменена дата открытия счёта %1 с %2 на %3", Счет, СчетОбъект.ДатаОткрытия, ДатаОткрытия), Счет,,, ЕстьИзменения);
			СчетОбъект.ДатаОткрытия = ДатаОткрытия;
		КонецЕсли;

		ДатаЗакрытия = ПреобразоватьСтрокуВДату(Лев(account.closedDate, 19));
		Если СчетОбъект.ДатаЗакрытия <> ДатаЗакрытия Тогда
			ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Изменена дата закрытия счёта %1 с %2 на %3", Счет, СчетОбъект.ДатаЗакрытия, ДатаЗакрытия), Счет,,, ЕстьИзменения);
			СчетОбъект.ДатаЗакрытия = ДатаЗакрытия;
		КонецЕсли;

		СчетОбъект.Активен = account.status = "ACCOUNT_STATUS_OPEN";

		СчетОбъект.Платформа = Справочники.Платформы.ТИнвестиции;
		СчетОбъект.ТипСчета = account.type;

		Если ЕстьИзменения Тогда
			СчетОбъект.Записать();
		КонецЕсли;

