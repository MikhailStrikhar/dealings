Процедура ПортфельПоСчету(Счет, currency = Неопределено, ПрочитатьГотовыеДанные = Ложь, СоздатьВводОстатков = Ложь) Экспорт
	
	Если ТипЗнч(Счет) = Тип("ВыборкаИзРезультатаЗапроса") Тогда
		AccountId = Счет.AccountId;
		СчетСсылка = Счет.Ссылка;
	ИначеЕсли ТипЗнч(Счет) = Тип("Строка") Тогда
		AccountId = Счет;
		СчетСсылка = Справочники.Счета.НайтиПоРеквизиту("AccountId", AccountId);
	ИначеЕсли ТипЗнч(Счет) = Тип("СправочникСсылка.Счета") Тогда
		AccountId = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Счет, "AccountId");
		СчетСсылка = Счет;
	Иначе
		ВызватьИсключение "неизвестный тип данных в процедуре ПортфельПоСчету - " + ТипЗнч(Счет);
	КонецЕсли;
	Тело = Новый Структура;
	Тело.Вставить("accountId", AccountId);
	Тело.Вставить("currency", "RUB");
	ТелоJSON = ms_РаботаСREST.TInvest_СериализоватьВJSON(Тело);
	ПараметрыЗапроса = Новый Структура("Тело", ТелоJSON);

	ДанныеСервиса = ms_РаботаСREST.TInvest_ВыполнитьЗапрос("POST", "OperationsService", "GetPortfolio", ПараметрыЗапроса);
	
	
//totalAmountShares Object (v1MoneyValue) Денежная сумма в определенной валюте.
//totalAmountBonds Object (v1MoneyValue) Денежная сумма в определенной валюте.
//totalAmountEtf Object (v1MoneyValue) Денежная сумма в определенной валюте.
//totalAmountCurrencies Object (v1MoneyValue) Денежная сумма в определенной валюте.
//totalAmountFutures Object (v1MoneyValue) Денежная сумма в определенной валюте.
//expectedYield Object (v1Quotation) Котировка — денежная сумма без указания валюты.
//positions Array of objects () Список позиций портфеля.
//accountId String Идентификатор счета пользователя.
//totalAmountOptions Object (v1MoneyValue) Денежная сумма в определенной валюте.
//totalAmountSp Object (v1MoneyValue) Денежная сумма в определенной валюте.
//totalAmountPortfolio Object (v1MoneyValue) Денежная сумма в определенной валюте.
//virtualPositions Array of objects () Массив виртуальных позиций портфеля.
//dailyYield  Object (v1MoneyValue) Денежная сумма в определенной валюте.
//dailyYieldRelative Object (v1Quotation) Котировка — денежная сумма без указания валюты.

	Если ПрочитатьГотовыеДанные Тогда
		ВременноеХранениеДанных = Справочники.ВременноеХранениеДанных.НайтиПоКоду("000000001");
		ДанныеСервиса = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВременноеХранениеДанных, "ХранилищеЗначения").Получить();
	Иначе
		ВременноеХранениеДанных = Справочники.ВременноеХранениеДанных.СоздатьЭлемент();
		ВременноеХранениеДанных.ХранилищеЗначения = Новый ХранилищеЗначения(ДанныеСервиса, Новый СжатиеДанных(9));
		ВременноеХранениеДанных.Записать();
		ОбщегоНазначения.СообщитьПользователю("Записаны данные " + ВременноеХранениеДанных, ВременноеХранениеДанных);
		//Записаны данные 000000001
	КонецЕсли;

	Если Не ДанныеСервиса.Свойство("positions") Тогда
		Сообщить("Нет данных");
		Возврат;
	КонецЕсли;
	
	positions = ДанныеСервиса.positions;
	
	Источник = Справочники.ИсточникиДанных.ТИнвест;
	КоличествоЗаписей = 0;
	Для Каждого position Из positions Цикл
		
		МенеджерЗаписи = РегистрыСведений.ИмпортДанныхБрокера.СоздатьМенеджерЗаписи();
		
		//Отбор.UID = СтруктураИнструмента.instrumentUid;
		//СтрокиИнструмента = Инструменты.НайтиСтроки(Отбор);
		//Если СтрокиИнструмента.Количество() = 1 Тогда
		//	Инструмент = СтрокиИнструмента[0].Ссылка;
		//Иначе
		//	Сообщить("Не найден инструмент по uid " + СтруктураИнструмента.instrumentUid);
		//	Продолжить;
		//КонецЕсли;
		МенеджерЗаписи.Период = ТекущаяДатаСеанса();
		МенеджерЗаписи.Инструмент = Справочники.Инструменты.ПолучитьИнструментПоУИД(position.instrumentUid);
		МенеджерЗаписи.instrumentUid = position.instrumentUid;
		МенеджерЗаписи.averagePositionPrice = СуммаИзКотировки(position.averagePositionPrice);
		МенеджерЗаписи.currency = position.averagePositionPrice.currency;
		МенеджерЗаписи.averagePositionPricePt = СуммаИзКотировки(position.averagePositionPricePt);
		МенеджерЗаписи.currency1 = position.averagePositionPrice.currency;
		МенеджерЗаписи.expectedYield = СуммаИзКотировки(position.expectedYield);
		МенеджерЗаписи.quantityLots = СуммаИзКотировки(position.quantityLots);
		МенеджерЗаписи.ticker = position.ticker;
		МенеджерЗаписи.Источник = Источник;
		МенеджерЗаписи.Счет = СчетСсылка;
		//МенеджерЗаписи.AccountId = AccountId;

		МенеджерЗаписи.Записать();
		КоличествоЗаписей = КоличествоЗаписей + 1;

	КонецЦикла;
	
	Если СоздатьВводОстатков Тогда
		ДокВвод = Документы.ВводНачальныхОстатков.СоздатьДокумент();
		ДокВвод.Дата = МенеджерЗаписи.Период;
		ДанныеЗаполнения = Новый Структура("Дата, Счет", ТекущаяДатаСеанса(), СчетСсылка);
		ДокВвод.Заполнить(ДанныеЗаполнения);
		Попытка
			ДокВвод.Записать();
			ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Создан документ %1, количество позиций: %2", ДокВвод.Ссылка, КоличествоЗаписей), ДокВвод.Ссылка);
		Исключение
			ОбщегоНазначения.СообщитьПользователю(ОписаниеОшибки());
		КонецПопытки;
	Иначе
		ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Загружены данные по счету %1, количество позиций: %2", СчетСсылка, КоличествоЗаписей));
	КонецЕсли;
	
КонецПроцедуры // ПортфельПоСчету

Функция TInvest_ПолучитьОперации(AccountId, ДатаС, ДатаПо, 
	Состояние = "OPERATION_STATE_EXECUTED", FIGI = "", Песочница = Ложь) Экспорт
	
	Если НЕ ЗначениеЗаполнено(AccountId) Тогда
		ВызватьИсключение "Не задан accountId";
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ДатаС) Или НЕ ЗначениеЗаполнено(ДатаПо) Тогда
		ВызватьИсключение "Не задан период (ДатаС/ДатаПо)";
	КонецЕсли;
	
	// Важно: API ожидает date-time в UTC строкой.
	// Здесь я даю простой формат ISO без миллисекунд.
	// Если у тебя даты уже локальные (через XMLЗначение), то это “локальный момент”, но строка будет без 'Z'.
	// Для MVP обычно достаточно: API принимает date-time строку, в документации указано UTC. :contentReference[oaicite:7]{index=7}
	Тело = Новый Структура;
	Тело.Вставить("accountId", AccountId);
	Тело.Вставить("from", Формат(ДатаС, "ДФ=yyyy-MM-dd'T'HH:mm:ss'Z'"));
	Тело.Вставить("to",   Формат(ДатаПо, "ДФ=yyyy-MM-dd'T'HH:mm:ss'Z'"));
	
	Если ЗначениеЗаполнено(Состояние) Тогда
		Тело.Вставить("state", Состояние);
	КонецЕсли;
	Если ЗначениеЗаполнено(FIGI) Тогда
		Тело.Вставить("figi", FIGI);
	КонецЕсли;
	
	ПараметрыЗапроса = Новый Структура("Тело", Тело);
	
	Возврат TInvest_ВыполнитьЗапрос("POST",
		"OperationsService",
		"GetOperations",
		ПараметрыЗапроса,
		Песочница);
		
КонецФункции

// Возвращает Массив операций (elements из ответа cursor-метода).
Функция TInvest_ПолучитьОперацииПоКурсору(AccountId, ДатаС, ДатаПо, 
	Лимит = 1000, Состояние = "OPERATION_STATE_EXECUTED", 
	InstrumentId = "", Песочница = Ложь) Экспорт
	
	Если НЕ ЗначениеЗаполнено(AccountId) Тогда
		ВызватьИсключение "Не задан accountId";
	КонецЕсли;
	
	Если Лимит <= 0 Тогда
		Лимит = 100;
	ИначеЕсли Лимит > 1000 Тогда
		Лимит = 1000;
	КонецЕсли;
	
	Результат = Новый Массив;
	Курсор = "";
	
	Пока Истина Цикл
		
		Тело = Новый Структура;
		Тело.Вставить("accountId", AccountId);
		Тело.Вставить("from", Формат(ДатаС, "ДФ=yyyy-MM-dd'T'HH:mm:ss'Z'"));
		Тело.Вставить("to",   Формат(ДатаПо, "ДФ=yyyy-MM-dd'T'HH:mm:ss'Z'"));
		Тело.Вставить("limit", Лимит);
		
		Если ЗначениеЗаполнено(Состояние) Тогда
			Тело.Вставить("state", Состояние);
		КонецЕсли;
		
		// instrumentId может быть UID или FIGI (по доке) :contentReference[oaicite:9]{index=9}
		Если ЗначениеЗаполнено(InstrumentId) Тогда
			Тело.Вставить("instrumentId", InstrumentId);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Курсор) Тогда
			Тело.Вставить("cursor", Курсор);
		КонецЕсли;
		
		ПараметрыЗапроса = Новый Структура("Тело", Тело);
		Ответ = TInvest_ВыполнитьЗапрос("POST",
			"OperationsService",
			"GetOperationsByCursor",
			ПараметрыЗапроса,
			Песочница);
		
		Если Ответ = Неопределено Тогда
			Возврат Результат;
		КонецЕсли;
		
		// В ответе: items/elements + nextCursor/hasNext (зависит от схемы)
		// По доке это cursor-ответ, так что ориентируйся на свойства курсора.
		Если Ответ.Свойство("items") Тогда
			Для Каждого Операция Из Ответ.items Цикл
				Результат.Добавить(Операция);
			КонецЦикла;
		ИначеЕсли Ответ.Свойство("operations") Тогда
			Для Каждого Операция Из Ответ.operations Цикл
				Результат.Добавить(Операция);
			КонецЦикла;
		КонецЕсли;
		
		ЕстьСледующий = Ложь;
		Если Ответ.Свойство("hasNext") Тогда
			ЕстьСледующий = Ответ.hasNext;
		КонецЕсли;
		
		Если Ответ.Свойство("nextCursor") Тогда
			Курсор = Ответ.nextCursor;
		ИначеЕсли Ответ.Свойство("cursor") Тогда
			// иногда возвращают просто cursor
			Курсор = Ответ.cursor;
		Иначе
			Курсор = "";
		КонецЕсли;
		
		Если НЕ ЕстьСледующий Или НЕ ЗначениеЗаполнено(Курсор) Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура TI_ИмпортироватьОперацииВСделки(Счет, ИсточникДанных, Операции) Экспорт
	
	КомиссииПоРодителю = TI_СобратьКомиссииПоРодителю(Операции);

	Для Каждого Операция Из Операции Цикл

		Если НЕ Операция.Свойство("operationType") Тогда
			Продолжить;
		КонецЕсли;

		// Берём только покупки/продажи. Комиссии подтянем по parentOperationId.
		Если Операция.operationType <> "OPERATION_TYPE_BUY"
		   И Операция.operationType <> "OPERATION_TYPE_SELL" Тогда
			Продолжить;
		КонецЕсли;

		OperationId = Операция.id;
		Если НЕ ЗначениеЗаполнено(OperationId) Тогда
			Продолжить;
		КонецЕсли;

		// анти-дубль
		ДокументСделкаСсылка = TI_НайтиДокументСделкаПоOperationId(Счет, OperationId);
		Если ДокументСделкаСсылка = Неопределено Тогда
			ДокументСделка = Документы.Сделка.СоздатьДокумент();
		Иначе
			СтратегияСделки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСделкаСсылка, "СтратегияСделки");
			Если ЗначениеЗаполнено(СтратегияСделки) Тогда
				ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Сделка %1 уже проведена, не загружаем повторно", ДокументСделкаСсылка), ДокументСделкаСсылка);
				Продолжить;
			Иначе
				ДокументСделка = ДокументСделкаСсылка.ПолучитьОбъект();
				ДокументСделка.Позиции.Очистить();
			КонецЕсли;
		КонецЕсли;

		// инструмент по instrumentUid (предпочтительнее, чем FIGI)
		InstrumentUid = Операция.instrumentUid;
		Если НЕ ЗначениеЗаполнено(InstrumentUid) Тогда
			// fallback на figi, если захочешь
			Продолжить;
		КонецЕсли;

		Инструмент = Справочники.Инструменты.ПолучитьИнструментПоУИД(InstrumentUid);

		ДокументСделка.Счет = Счет;
		ДокументСделка.Дата = ПреобразоватьСтрокуВДату(Операция.date);
		ДокументСделка.ВидСделки = 
			?(Операция.operationType = "OPERATION_TYPE_BUY",
			  Перечисления.ВидыСделок.Покупка,
			  Перечисления.ВидыСделок.Продажа);
			  
		Валюта = Справочники.Валюты.НайтиПоНаименованию(Операция.currency);
		ДокументСделка.ВалютаСделки = Валюта;
		Если Операция.currency = "rub" Тогда
			ДокументСделка.КурсСделки = 1;
		Иначе
			ДокументСделка.КурсСделки = РасчетыВДокументах.КурсВалютыНаДату(ДокументСделка.Дата, Валюта);
		КонецЕсли;
		ДокументСделка.OperationId = Операция.id;
		ДокументСделка.Источник = ИсточникДанных;

		Стр = ДокументСделка.Позиции.Добавить();

		Стр.Инструмент = Инструмент;

		Количество = Число(Операция.quantity);
		Стр.Количество = Количество;

		РазмерЛота = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Инструмент, "РазмерЛота");
		Если РазмерЛота <> 0 Тогда
			Стр.КоличествоЛотов = Количество / РазмерЛота;
		Иначе
			Стр.КоличествоЛотов = Количество;
		КонецЕсли;

		Стр.Цена = СуммаИзКотировки(Операция.price);

		Комиссия = КомиссииПоРодителю.Получить(Операция.id);
		Если Комиссия = Неопределено Тогда Комиссия = 0; КонецЕсли;
		Стр.Комиссия = Комиссия;

		ДокументСделка.Записать();
		ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Записан документ %1", ДокументСделка.Ссылка), ДокументСделка.Ссылка);

	КонецЦикла;

КонецПроцедуры

Функция TI_СобратьКомиссииПоРодителюУниверсально(Операции) Экспорт
	Комиссии = Новый Соответствие; // key: parentId, value: сумма (положительная)

	Для Каждого Оп Из Операции Цикл

		// 1) Классика: отдельная операция комиссии (BROKER_FEE) с parentOperationId
		Если Оп.Свойство("operationType") И Оп.operationType = "OPERATION_TYPE_BROKER_FEE" Тогда
			ParentId = TI_ПолучитьСвойство(Оп, "parentOperationId");
			Если ЗначениеЗаполнено(ParentId) Тогда
				Сумма = -СуммаИзКотировки(TI_ПолучитьСвойство(Оп, "payment"));
				Если Сумма < 0 Тогда Сумма = -Сумма; КонецЕсли;
				Тек = Комиссии.Получить(ParentId); Если Тек = Неопределено Тогда Тек = 0; КонецЕсли;
				Комиссии.Вставить(ParentId, Тек + Сумма);
			КонецЕсли;
		КонецЕсли;

		// 2) Cursor/прочие варианты: комиссия в childOperations без id
		ChildOps = TI_ПолучитьСвойство(Оп, "childOperations");
		Если ТипЗнч(ChildOps) = Тип("Массив") Тогда
			Для Каждого Ч Из ChildOps Цикл
				Платеж = TI_ПолучитьСвойство(Ч, "payment");
				Если Платеж <> Неопределено Тогда
					Сумма = -СуммаИзКотировки(Платеж);
					Если Сумма < 0 Тогда Сумма = -Сумма; КонецЕсли;
					Тек = Комиссии.Получить(Оп.id); Если Тек = Неопределено Тогда Тек = 0; КонецЕсли;
					Комиссии.Вставить(Оп.id, Тек + Сумма);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;

	КонецЦикла;

	Возврат Комиссии;
КонецФункции

Процедура TI_ИмпортироватьОперацииПоКурсоруВСделки(Счет, ИсточникДанных, ОтветКурсора) Экспорт

	Если ОтветКурсора = Неопределено Тогда Возврат; КонецЕсли;

	// В cursor-ответе обычно items, но подстрахуемся.
	Операции = Неопределено;
	Если ТипЗнч(ОтветКурсора) = Тип("Массив") Тогда
		Операции = ОтветКурсора;
	ИначеЕсли ОтветКурсора.Свойство("items") Тогда
		Операции = ОтветКурсора.items;
	ИначеЕсли ОтветКурсора.Свойство("operations") Тогда
		Операции = ОтветКурсора.operations;
	Иначе
		Возврат;
	КонецЕсли;

	КомиссииПоРодителю = TI_СобратьКомиссииПоРодителюУниверсально(Операции);

	Для Каждого Операция Из Операции Цикл

		ТипОпер = TI_ТипОперации(Операция);

		// Иногда type человекочитаемый. Тогда пытаемся опознать по operationTypeName/operationType не вышло.
		Если ТипОпер = "Покупка ценных бумаг" Тогда ТипОпер = "OPERATION_TYPE_BUY"; КонецЕсли;
		Если ТипОпер = "Продажа ценных бумаг" Тогда ТипОпер = "OPERATION_TYPE_SELL"; КонецЕсли;

		Если ТипОпер <> "OPERATION_TYPE_BUY"
		   И ТипОпер <> "OPERATION_TYPE_SELL" Тогда
			Продолжить;
		КонецЕсли;

		OperationId = TI_ПолучитьСвойство(Операция, "id");
		Если НЕ ЗначениеЗаполнено(OperationId) Тогда Продолжить; КонецЕсли;

		// анти-дубль / обновление
		ДокументСделкаСсылка = TI_НайтиДокументСделкаПоOperationId(Счет, OperationId);
		Если ДокументСделкаСсылка = Неопределено Тогда
			ДокументСделка = Документы.Сделка.СоздатьДокумент();
		Иначе
			СтратегияСделки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСделкаСсылка, "СтратегияСделки");
			Если ЗначениеЗаполнено(СтратегияСделки) Тогда
				Продолжить;
			Иначе
				ДокументСделка = ДокументСделкаСсылка.ПолучитьОбъект();
				// можно очистить ТЧ, если хочешь “перезалить”
				ДокументСделка.Позиции.Очистить();
			КонецЕсли;
		КонецЕсли;

		InstrumentUid = TI_ПолучитьСвойство(Операция, "instrumentUid");
		Если НЕ ЗначениеЗаполнено(InstrumentUid) Тогда
			Продолжить;
		КонецЕсли;

		Инструмент = Справочники.Инструменты.ПолучитьИнструментПоУИД(InstrumentUid);

		ДатаISO = TI_ПолучитьСвойство(Операция, "date", "dateTime");
		ДокументСделка.Дата = ПреобразоватьСтрокуВДату(ДатаISO);

		ДокументСделка.Счет = Счет;
		ДокументСделка.ВидСделки =
			?(ТипОпер = "OPERATION_TYPE_BUY",
			  Перечисления.ВидыСделок.Покупка,
			  Перечисления.ВидыСделок.Продажа);

		// Валюта: в cursor-формате часто только внутри price/payment
		КодВалюты = TI_ВалютаИзЦеныИлиПлатежа(Операция);
		Если ЗначениеЗаполнено(КодВалюты) Тогда
			Валюта = Справочники.Валюты.НайтиПоНаименованию(КодВалюты);
			ДокументСделка.ВалютаСделки = Валюта;

			Если КодВалюты = "rub" Тогда
				ДокументСделка.КурсСделки = 1;
			Иначе
				ДокументСделка.КурсСделки = РасчетыВДокументах.КурсВалютыНаДату(ДокументСделка.Дата, Валюта);
			КонецЕсли;
		КонецЕсли;

		ДокументСделка.OperationId = OperationId;
		ДокументСделка.Источник = ИсточникДанных;

		Стр = ДокументСделка.Позиции.Добавить();
		Стр.Инструмент = Инструмент;

		Количество = Число(TI_ПолучитьСвойство(Операция, "quantity", "quantityUnits"));
		Стр.Количество = Количество;

		РазмерЛота = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Инструмент, "РазмерЛота");
		Если РазмерЛота <> 0 Тогда
			Стр.КоличествоЛотов = Количество / РазмерЛота;
		Иначе
			Стр.КоличествоЛотов = Количество;
		КонецЕсли;

		ЦенаСтр = TI_ПолучитьСвойство(Операция, "price");
		Если ЦенаСтр <> Неопределено Тогда
			Стр.Цена = СуммаИзКотировки(ЦенаСтр);
		Иначе
			// иногда бывает без price, тогда можно оценить через payment/quantity, но лучше пропустить
			Стр.Цена = 0;
		КонецЕсли;

		Комиссия = КомиссииПоРодителю.Получить(OperationId);
		Если Комиссия = Неопределено Тогда Комиссия = 0; КонецЕсли;
		Стр.Комиссия = Комиссия;

		ДокументСделка.Записать();
		ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Записан документ %1", ДокументСделка.Ссылка), ДокументСделка.Ссылка);

	КонецЦикла;

КонецПроцедуры

#КонецОбласти

