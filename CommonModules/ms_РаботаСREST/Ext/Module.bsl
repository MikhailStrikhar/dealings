//	Данные = TInvest_ПрочитатьJSON(ТекстОтвета);
//Возврат Данные;
	
	Запрос.Заголовки.Вставить("Authorization", "Bearer " + Токен);
	Запрос.Заголовки.Вставить("Content-Type", "application/json");
	Запрос.Заголовки.Вставить("Accept", "application/json");

	Ответ = Соединение.ВызватьHTTPМетод(Метод, Запрос);

	Если Ответ.КодСостояния <> 200 Тогда
		ТекстОшибки = Ответ.ПолучитьТелоКакСтроку();
		Если Ответ.КодСостояния = 404 Тогда
			Результат = Новый Структура("Ошибка, ОписаниеОшибки", Истина, ТекстОшибки);
		Иначе
			// Для отладки удобно вернуть текст ошибки
			ВызватьИсключение СтрШаблон("Сервис T-Invest при обращении к методу %3 сообщил об ошибке: %1. 
							|%2
							|Тело: %4", Ответ.КодСостояния, ТекстОшибки, ИмяКоманды, ТелоJSON);
		КонецЕсли;
	КонецЕсли;

	ТекстОтвета = Ответ.ПолучитьТелоКакСтроку();
	Результат = TInvest_ПрочитатьJSON(ТекстОтвета);

	// Обычно в ответе массив инструментов. Конкретное имя поля зависит от схемы ответа в Swagger.
	// Поэтому возвращаем весь разобранный объект, а дальше ты уже выберешь нужное (figi/uid/ticker).
	Возврат Результат;

КонецФункции

Функция TInvest_СериализоватьВJSON(Значение) Экспорт
	
	Запись = Новый ЗаписьJSON;
	Запись.УстановитьСтроку();
	ЗаписатьJSON(Запись, Значение);
	Возврат Запись.Закрыть();
	
КонецФункции

Функция TInvest_ПрочитатьJSON(СтрокаJSON) Экспорт
	
	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(СтрокаJSON);
	Возврат ПрочитатьJSON(Чтение);
	
КонецФункции

Функция СуммаИзКотировки(Котировка) Экспорт
	
	Если Котировка = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	// units приходит строкой
	ЦелаяЧасть = Число(Котировка.units);
	ДробнаяЧасть = Котировка.nano / 1000000000;

	Возврат ЦелаяЧасть + ДробнаяЧасть;

КонецФункции

Функция ПреобразоватьСтрокуВДату(Значение)
	
	Если Значение = "1970-01-01T00:00:00" ИЛИ Значение = "1970-01-01T00:00:00Z" Тогда
		Возврат Дата(1, 1, 1);
	КонецЕсли;
	Дата = XMLЗначение(Тип("Дата"), Значение);
	Если Год(Дата) = 1970 И Месяц(Дата) = 1 И День(Дата) = 1 Тогда
		Дата = Дата(1, 1, 1);
	КонецЕсли;
	Возврат Дата;

КонецФункции // ПреобразоватьСтрокуВДату()

Функция TI_СобратьКомиссииПоРодителю(Операции) Экспорт
	Комиссии = Новый Соответствие; // key: parentOperationId, value: сумма комиссии (положительное число)

	Для Каждого Операция Из Операции Цикл
		Если Операция.Свойство("operationType") 
			И Операция.operationType = "OPERATION_TYPE_BROKER_FEE"
			И ЗначениеЗаполнено(Операция.parentOperationId) Тогда

			Сумма = -СуммаИзКотировки(Операция.payment); // payment отрицательный, комиссию храним положительной
			Если Сумма < 0 Тогда
				Сумма = -Сумма;
			КонецЕсли;

			КомиссияСделки = Комиссии.Получить(Операция.parentOperationId);
			Если КомиссияСделки = Неопределено Тогда КомиссияСделки = 0; КонецЕсли;

			Комиссии.Вставить(Операция.parentOperationId, КомиссияСделки + Сумма);
		КонецЕсли;
	КонецЦикла;

	Возврат Комиссии;
КонецФункции

Функция TI_НайтиДокументСделкаПоOperationId(Счет, OperationId) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Сделка.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Сделка КАК Сделка
	|ГДЕ
	|	Сделка.Счет = &Счет
	|	И Сделка.OperationId = &OperationId";

	Запрос.УстановитьПараметр("Счет", Счет);
	Запрос.УстановитьПараметр("OperationId", OperationId);

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;

	Возврат Неопределено;
КонецФункции

Функция TI_ПолучитьСвойство(СтруктураДанных, Имя1, Имя2 = "", Имя3 = "") Экспорт
	Если СтруктураДанных = Неопределено Тогда Возврат Неопределено; КонецЕсли;

	Если ЗначениеЗаполнено(Имя1) И СтруктураДанных.Свойство(Имя1) Тогда Возврат СтруктураДанных[Имя1]; КонецЕсли;
	Если ЗначениеЗаполнено(Имя2) И СтруктураДанных.Свойство(Имя2) Тогда Возврат СтруктураДанных[Имя2]; КонецЕсли;
	Если ЗначениеЗаполнено(Имя3) И СтруктураДанных.Свойство(Имя3) Тогда Возврат СтруктураДанных[Имя3]; КонецЕсли;

	Возврат Неопределено;
КонецФункции

Функция TI_ВалютаИзЦеныИлиПлатежа(Операция) Экспорт
	Цена = TI_ПолучитьСвойство(Операция, "price");
	Если Цена <> Неопределено Тогда
		Вал = TI_ПолучитьСвойство(Цена, "currency");
		Если ЗначениеЗаполнено(Вал) Тогда Возврат Вал; КонецЕсли;
	КонецЕсли;

	Платеж = TI_ПолучитьСвойство(Операция, "payment");
	Если Платеж <> Неопределено Тогда
		Вал = TI_ПолучитьСвойство(Платеж, "currency");
		Если ЗначениеЗаполнено(Вал) Тогда Возврат Вал; КонецЕсли;
	КонецЕсли;

	Возврат "";
КонецФункции

Функция TI_ТипОперации(Операция) Экспорт
	// В разных форматах может быть:
	// operationType: "OPERATION_TYPE_BUY"
	// type: "OPERATION_TYPE_BUY" или человекочитаемое "Покупка ценных бумаг"
	Тип = TI_ПолучитьСвойство(Операция, "operationType");
	Если ЗначениеЗаполнено(Тип) Тогда Возврат Тип; КонецЕсли;

	Тип = TI_ПолучитьСвойство(Операция, "type");
	Если ЗначениеЗаполнено(Тип) Тогда Возврат Тип; КонецЕсли;

	Возврат "";
КонецФункции

