Процедура ЗаписатьОшибкуВЖурналРегистрации(Комментарий, ИсточникДанных)
	
	ЗаписьЖурналаРегистрации(НСтр("ru = 'Работа с API'", ОбщегоНазначения.КодОсновногоЯзыка()),
		УровеньЖурналаРегистрации.Ошибка, , ИсточникДанных, Комментарий);
	
КонецПроцедуры

Функция ТекстОшибки(ТекстОшибки)
	
	Если Пользователи.ЭтоПолноправныйПользователь() Тогда
		Возврат ТекстОшибки + Символы.ПС + НСтр("ru = 'Подробности см. в журнале регистрации.'");
	КонецЕсли;
	
	Возврат ТекстОшибки + Символы.ПС + НСтр("ru = 'Обратитесь к администратору.'");
	
КонецФункции

Функция TInvest_ВыполнитьЗапрос(Метод = "POST", РазделAPI, ИмяКоманды, ПараметрыЗапроса, Песочница = Ложь) Экспорт
	
	//СтрокаПоиска ="?"; КлассКод = "INSTRUMENT_TYPE_UNSPECIFIED";
	//// ТолькоТоргуемые = Истина, 
	//
	//Если НЕ ЗначениеЗаполнено(СтрокаПоиска) Тогда
	//	Возврат Неопределено;
	//КонецЕсли;       
	
	РеквизитыИсточникаДанных = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Справочники.ИсточникиДанных.ТИнвест, "Адрес, Путь, Порт");
	
	Если ПараметрыЗапроса.Свойство("Токен") И ЗначениеЗаполнено(ПараметрыЗапроса.Токен) Тогда
		Токен = ПараметрыЗапроса.Токен;
	Иначе
		Владелец = ОбщегоНазначения.ИдентификаторОбъектаМетаданных("Справочник.ИсточникиДанных");
		ИмяСервиса = Справочники.ИсточникиДанных.ТИнвест.Наименование;
		Токен = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(Владелец, ИмяСервиса);
	КонецЕсли;
	
	// Host для REST-прокси
	Хост = ?(Песочница, "sandbox-invest-public-api.tbank.ru", РеквизитыИсточникаДанных.Адрес);
	Порт = РеквизитыИсточникаДанных.Порт;

	// Путь метода (REST proxy)
	Путь = РеквизитыИсточникаДанных.Путь + "." + РазделAPI + "/" + ИмяКоманды;

	//// Тело запроса
	//Тело = Новый Структура;
	//ЗаполнитьЗначенияСвойств(ПараметрыЗапроса.Тело, ПараметрыЗапроса);
	////Тело.Вставить("id_type", "INSTRUMENT_ID_TYPE_TICKER");
