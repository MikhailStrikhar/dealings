
#Область ПрограммныйИнтерфейс

// ЗагрузитьПоследниеЦеныПоИнструментам(Знач Инструменты = Неопределено, КоличествоЗаписей)
// Получает последние цены по инструментам через метод GetLastPrices и записывает их в регистр сведений ТекущиеЦены.
// Параметры:
// Инструменты -- таблица значений с колонкой UID; если не задана, список инструментов определяется по текущим остаткам регистра ПозицииИнструментов
// КоличествоЗаписей -- выходной параметр, количество записанных цен
// Результат:
// выполняется запись данных в регистр ТекущиеЦены
// Особенности:
// отбираются только инструменты с заполненным UID
// инструмент сопоставляется по UID
// если инструмент не найден, выводится сообщение пользователю
Процедура ЗагрузитьПоследниеЦеныПоИнструментам(Знач Инструменты = Неопределено, КоличествоЗаписей) Экспорт
	
	lastPrices = ИнтеграцияTInvestAPI.ПолучитьПоследниеЦеныПоИнструментам(Инструменты = Неопределено, КоличествоЗаписей);
	
	Отбор = Новый Структура("UID");
	Источник = Справочники.ИсточникиДанных.ТИнвест;
	
	КоличествоЗаписей = 0;
	Для Каждого СтруктураИнструмента Из lastPrices Цикл
		
		Если СтруктураИнструмента.lastPriceType = "LAST_PRICE_UNSPECIFIED" Тогда
			Продолжить;
		КонецЕсли;
		Если Не СтруктураИнструмента.Свойство("time") Тогда
			Продолжить;
		КонецЕсли;
		
		МенеджерЗаписи = РегистрыСведений.ИсторияЦенИнструментов.СоздатьМенеджерЗаписи();
		
		Отбор.UID = СтруктураИнструмента.instrumentUid;
		СтрокиИнструмента = Инструменты.НайтиСтроки(Отбор);
		Если СтрокиИнструмента.Количество() = 1 Тогда
			Инструмент = СтрокиИнструмента[0].Ссылка;
		Иначе
			Сообщить("Не найден инструмент по uid " + СтруктураИнструмента.instrumentUid);
			Продолжить;
		КонецЕсли;
		МенеджерЗаписи.Период = ИнтеграцияTInvestСлужебный.ПреобразоватьСтрокуВДату(Лев(СтруктураИнструмента.time, 19));
		МенеджерЗаписи.Инструмент = Инструмент;
		МенеджерЗаписи.Цена = ИнтеграцияTInvestСлужебный.СуммаИзКотировки(СтруктураИнструмента.price);
		МенеджерЗаписи.lastPriceType = СтруктураИнструмента.lastPriceType;
		МенеджерЗаписи.Источник = Источник;

		МенеджерЗаписи.Записать();
		КоличествоЗаписей = КоличествоЗаписей + 1;
		
	КонецЦикла;
	
КонецПроцедуры

// ЗагрузитьПортфельПоСчету(Счет, currency = Неопределено, ПрочитатьГотовыеДанные = Ложь, СоздатьВводОстатков = Ложь)
// Получает портфель по счёту через GetPortfolio, сохраняет импортированные данные в регистр ИмпортДанныхБрокера и при необходимости создаёт документ ВводНачальныхОстатков.
// Параметры:
// Счет -- счёт в одном из допустимых представлений:
// ссылка на справочник Счета
// строковый AccountId
// строка выборки запроса
// currency -- валюта запроса, в текущей реализации фактически игнорируется, жёстко используется "RUB"
// ПрочитатьГотовыеДанные -- читать ранее сохранённые данные из временного хранилища
// СоздатьВводОстатков -- создавать документ ВводНачальныхОстатков
// Результат:
// записывает позиции в регистр ИмпортДанныхБрокера
// опционально создаёт документ ВводНачальныхОстатков
// Особенности:
// данные сервиса дополнительно сохраняются в справочник ВременноеХранениеДанных
// инструмент определяется по instrumentUid
// Замечания:
// метод сочетает получение, кэширование, импорт и создание документа
// параметр currency сейчас реализован неверно, так как не используется по значению
Процедура ЗагрузитьПортфельПоСчету(Счет, currency = "RUB", ПрочитатьГотовыеДанные = Ложь, СоздатьВводОстатков = Ложь) Экспорт
	
	ДанныеСервиса = ИнтеграцияTInvestAPI.TInvest_ПолучитьПортфельПоСчету(Счет, currency, ПрочитатьГотовыеДанные);
	positions = ДанныеСервиса.positions;
	СчетСсылка = ДанныеСервиса.СчетСсылка;
	
	Если Не ЗначениеЗаполнено(positions) Тогда
		Возврат;
	КонецЕсли;
	
	Источник = Справочники.ИсточникиДанных.ТИнвест;
	КоличествоЗаписей = 0;
	Для Каждого position Из positions Цикл
		
		МенеджерЗаписи = РегистрыСведений.ИмпортДанныхБрокера.СоздатьМенеджерЗаписи();
		
		МенеджерЗаписи.Период = ТекущаяДатаСеанса();
		МенеджерЗаписи.Инструмент = Справочники.Инструменты.ПолучитьИнструментПоУИД(position.instrumentUid);
		МенеджерЗаписи.instrumentUid = position.instrumentUid;
		МенеджерЗаписи.averagePositionPrice = ИнтеграцияTInvestСлужебный.СуммаИзКотировки(position.averagePositionPrice);
		МенеджерЗаписи.currency = position.averagePositionPrice.currency;
		МенеджерЗаписи.averagePositionPricePt = ИнтеграцияTInvestСлужебный.СуммаИзКотировки(position.averagePositionPricePt);
		МенеджерЗаписи.currency1 = position.averagePositionPrice.currency;
		МенеджерЗаписи.expectedYield = ИнтеграцияTInvestСлужебный.СуммаИзКотировки(position.expectedYield);
		МенеджерЗаписи.quantityLots = ИнтеграцияTInvestСлужебный.СуммаИзКотировки(position.quantityLots);
		МенеджерЗаписи.ticker = position.ticker;
		МенеджерЗаписи.Источник = Источник;
		МенеджерЗаписи.Счет = СчетСсылка;

		МенеджерЗаписи.Записать();
		КоличествоЗаписей = КоличествоЗаписей + 1;

	КонецЦикла;
	
	Если СоздатьВводОстатков Тогда
		ДокВвод = Документы.ВводНачальныхОстатков.СоздатьДокумент();
		ДокВвод.Дата = МенеджерЗаписи.Период;
		ДанныеЗаполнения = Новый Структура("Дата, Счет", ТекущаяДатаСеанса(), СчетСсылка);
		ДокВвод.Заполнить(ДанныеЗаполнения);
		Попытка
			ДокВвод.Записать();
			ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Создан документ %1, количество позиций: %2", ДокВвод.Ссылка, КоличествоЗаписей), ДокВвод.Ссылка);
		Исключение
			ОбщегоНазначения.СообщитьПользователю(ОписаниеОшибки());
		КонецПопытки;
	Иначе
		ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Загружены данные по счету %1, количество позиций: %2", СчетСсылка, КоличествоЗаписей));
	КонецЕсли;
	
КонецПроцедуры // ЗагрузитьПортфельПоСчету

// Загружает свечи по инструменту и записывает их в регистр сведений СвечиИнструментов.
// Параметры:
//  Инструмент      - СправочникСсылка.Инструменты
//  ДатаНачала      - Дата
//  ДатаОкончания   - Дата
//  Таймфрейм       - ПеречислениеСсылка.ТаймфреймыСвечей
// Возвращает:
//  Число - количество записанных/обновленных свечей
Функция ЗагрузитьСвечиПоИнструменту(Инструмент, ДатаНачала, ДатаОкончания, Таймфрейм) Экспорт
    
    ПроверитьПараметрыЗагрузкиСвечей(Инструмент, ДатаНачала, ДатаОкончания, Таймфрейм);
    
    ИдентификаторИнструмента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Инструмент, "UID");
    ИнтервалAPI = Перечисления.ТаймфреймыСвечей.ПолучитьИнтервалСвечейAPI(Таймфрейм);
    
    МассивСвечейAPI = ИнтеграцияTInvestAPI.ПолучитьСвечи(
        ИдентификаторИнструмента,
        ДатаНачала,
        ДатаОкончания,
        ИнтервалAPI
    );
    
    Если МассивСвечейAPI = Неопределено Или МассивСвечейAPI.Количество() = 0 Тогда
        Возврат 0;
    КонецЕсли;
    
    ТаблицаСвечей = ПреобразоватьСвечиAPIВТаблицу(Инструмент, Таймфрейм, МассивСвечейAPI);
    КоличествоЗаписей = ЗаписатьСвечиВРегистр(ТаблицаСвечей);
    
    Возврат КоличествоЗаписей;
    
КонецФункции

#КонецОбласти

