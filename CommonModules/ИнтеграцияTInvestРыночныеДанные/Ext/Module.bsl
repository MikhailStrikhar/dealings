Функция ПреобразоватьСвечиAPIВТаблицу(Инструмент, Таймфрейм, МассивСвечейAPI)
    
    Таблица = Новый ТаблицаЗначений;
    Таблица.Колонки.Добавить("Период", Новый ОписаниеТипов("Дата"));
    Таблица.Колонки.Добавить("Инструмент");
    Таблица.Колонки.Добавить("Таймфрейм");
    Таблица.Колонки.Добавить("Open", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 6)));
    Таблица.Колонки.Добавить("High", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 6)));
    Таблица.Колонки.Добавить("Low", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 6)));
    Таблица.Колонки.Добавить("Close", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 6)));
    Таблица.Колонки.Добавить("Volume", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 0)));
    Таблица.Колонки.Добавить("Источник");
    
    Для Каждого СвечаAPI Из МассивСвечейAPI Цикл
        
        СтрокаТаблицы = Таблица.Добавить();
        СтрокаТаблицы.Период = ИнтеграцияTInvestСлужебный.ПреобразоватьСтрокуВДату(СвечаAPI.time);
        СтрокаТаблицы.Инструмент = Инструмент;
        СтрокаТаблицы.Таймфрейм = Таймфрейм;
        СтрокаТаблицы.Open = ИнтеграцияTInvestСлужебный.СуммаИзКотировки(СвечаAPI.open);
        СтрокаТаблицы.High = ИнтеграцияTInvestСлужебный.СуммаИзКотировки(СвечаAPI.high);
        СтрокаТаблицы.Low = ИнтеграцияTInvestСлужебный.СуммаИзКотировки(СвечаAPI.low);
        СтрокаТаблицы.Close = ИнтеграцияTInvestСлужебный.СуммаИзКотировки(СвечаAPI.close);
        СтрокаТаблицы.Volume = ?(СвечаAPI.Свойство("volume"), СвечаAPI.volume, 0);
        СтрокаТаблицы.Источник = Справочники.ИсточникиДанных.ТИнвест;
        
    КонецЦикла;
    
    Возврат Таблица;
    
КонецФункции

Функция ЗаписатьСвечиВРегистр(ТаблицаСвечей)
    
    Если ТаблицаСвечей.Количество() = 0 Тогда
        Возврат 0;
    КонецЕсли;
    
    Инструмент = ТаблицаСвечей[0].Инструмент;
    Таймфрейм = ТаблицаСвечей[0].Таймфрейм;
    
    МинПериод = ТаблицаСвечей[0].Период;
    МаксПериод = ТаблицаСвечей[0].Период;
    
    Для Каждого СтрокаСвечи Из ТаблицаСвечей Цикл
        Если СтрокаСвечи.Период < МинПериод Тогда
            МинПериод = СтрокаСвечи.Период;
        КонецЕсли;
        Если СтрокаСвечи.Период > МаксПериод Тогда
            МаксПериод = СтрокаСвечи.Период;
        КонецЕсли;
    КонецЦикла;
    
    СуществующиеСвечи = ПолучитьСуществующиеСвечи(Инструмент, Таймфрейм, МинПериод, МаксПериод);
    ИндексСуществующих = ПостроитьИндексСвечей(СуществующиеСвечи);
    
    НаборЗаписей = РегистрыСведений.СвечиИнструментов.СоздатьНаборЗаписей();
    КоличествоИзменений = 0;
    
    Для Каждого СтрокаСвечи Из ТаблицаСвечей Цикл
        
        Ключ = ПолучитьКлючСвечи(СтрокаСвечи.Период, СтрокаСвечи.Инструмент, СтрокаСвечи.Таймфрейм);
		
		СуществующаяСтрока = ИндексСуществующих.Получить(Ключ);
		Если СуществующаяСтрока <> Неопределено Тогда
		//Если ИндексСуществующих.Свойство(Ключ, СуществующаяСтрока) Тогда
		    
		    Если СвечаИзменилась(СуществующаяСтрока, СтрокаСвечи) Тогда
		        Запись = НаборЗаписей.Добавить();
		        Запись.Период = СтрокаСвечи.Период;
		        Запись.Инструмент = СтрокаСвечи.Инструмент;
		        Запись.Таймфрейм = СтрокаСвечи.Таймфрейм;
		        Запись.Open = СтрокаСвечи.Open;
		        Запись.High = СтрокаСвечи.High;
		        Запись.Low = СтрокаСвечи.Low;
		        Запись.Close = СтрокаСвечи.Close;
		        Запись.Volume = СтрокаСвечи.Volume;
		        Запись.Источник = СтрокаСвечи.Источник;
		        КоличествоИзменений = КоличествоИзменений + 1;
		    КонецЕсли;
		    
		Иначе
		    
		    Запись = НаборЗаписей.Добавить();
		    Запись.Период = СтрокаСвечи.Период;
		    Запись.Инструмент = СтрокаСвечи.Инструмент;
		    Запись.Таймфрейм = СтрокаСвечи.Таймфрейм;
		    Запись.Open = СтрокаСвечи.Open;
		    Запись.High = СтрокаСвечи.High;
		    Запись.Low = СтрокаСвечи.Low;
		    Запись.Close = СтрокаСвечи.Close;
		    Запись.Volume = СтрокаСвечи.Volume;
		    Запись.Источник = СтрокаСвечи.Источник;
		    КоличествоИзменений = КоличествоИзменений + 1;
		    
		КонецЕсли;
        
    КонецЦикла;
    
    Если КоличествоИзменений > 0 Тогда
        НаборЗаписей.Записать();
    КонецЕсли;
    
    Возврат КоличествоИзменений;
    
КонецФункции

Функция ПолучитьСуществующиеСвечи(Инструмент, Таймфрейм, ДатаНачала, ДатаОкончания)
    
    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |   Свечи.Период КАК Период,
    |   Свечи.Инструмент КАК Инструмент,
    |   Свечи.Таймфрейм КАК Таймфрейм,
    |   Свечи.Open КАК Open,
    |   Свечи.High КАК High,
    |   Свечи.Low КАК Low,
    |   Свечи.Close КАК Close,
    |   Свечи.Volume КАК Volume,
    |   Свечи.Источник КАК Источник
    |ИЗ
    |   РегистрСведений.СвечиИнструментов КАК Свечи
    |ГДЕ
    |   Свечи.Инструмент = &Инструмент
    |   И Свечи.Таймфрейм = &Таймфрейм
    |   И Свечи.Период МЕЖДУ &ДатаНачала И &ДатаОкончания";
    
    Запрос.УстановитьПараметр("Инструмент", Инструмент);
    Запрос.УстановитьПараметр("Таймфрейм", Таймфрейм);
    Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
    Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
    
    Возврат Запрос.Выполнить().Выгрузить();
    
КонецФункции

Функция ПостроитьИндексСвечей(ТаблицаСвечей)
    
    Индекс = Новый Соответствие;
    
    Для Каждого СтрокаСвечи Из ТаблицаСвечей Цикл
        Ключ = ПолучитьКлючСвечи(СтрокаСвечи.Период, СтрокаСвечи.Инструмент, СтрокаСвечи.Таймфрейм);
        Индекс.Вставить(Ключ, СтрокаСвечи);
    КонецЦикла;
    
    Возврат Индекс;
    
КонецФункции

Функция ПолучитьКлючСвечи(Период, Инструмент, Таймфрейм)
    Возврат Формат(Период, "ДФ=yyyyMMddHHmmss") + "|" + Строка(Инструмент) + "|" + Строка(Таймфрейм);
КонецФункции

Функция СвечаИзменилась(СуществующаяСтрока, НоваяСтрока)
    
    Возврат
        СуществующаяСтрока.Open <> НоваяСтрока.Open
        Или СуществующаяСтрока.High <> НоваяСтрока.High
        Или СуществующаяСтрока.Low <> НоваяСтрока.Low
        Или СуществующаяСтрока.Close <> НоваяСтрока.Close
        Или СуществующаяСтрока.Volume <> НоваяСтрока.Volume
        Или СуществующаяСтрока.Источник <> НоваяСтрока.Источник;
    
КонецФункции
	
#КонецОбласти
	