Функция СписокОбъектовMarkdown(Заголовок, КоллекцияМетаданных, ПрефиксURI) Экспорт
	
	Текст = "# " + Заголовок + Символы.ПС;

	Для Каждого ОбъектМД Из КоллекцияМетаданных Цикл
		URI = ПрефиксURI + ОбъектМД.Имя;
		Текст = Текст + "- " + ОбъектМД.Имя;
		Если ЗначениеЗаполнено(ОбъектМД.Синоним) Тогда
			Текст = Текст + " (" + ОбъектМД.Синоним + ")";
		КонецЕсли;
		Текст = Текст + " — " + URI + Символы.ПС;
	КонецЦикла;

	Возврат Текст;

КонецФункции

Функция ТекстСтруктуры(ТипМетаданных, ИмяОбъекта) Экспорт
	
	ТаблицаИнструментов = mcp_КонтейнерыПовтИсп.Инструменты();

	СтрокаИнструмента = Неопределено;
	Для Каждого Стр Из ТаблицаИнструментов Цикл
		Если Стр.Имя = "get_metadata_structure" Тогда
			СтрокаИнструмента = Стр;
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Если СтрокаИнструмента = Неопределено Тогда
		ВызватьИсключение "Инструмент get_metadata_structure не найден";
	КонецЕсли;

	Аргументы = Новый Структура;
	Аргументы.Вставить("metaType", ТипМетаданных);
	Аргументы.Вставить("name", ИмяОбъекта);

	Результат = mcp_Выполнение.ВыполнитьИнструмент(СтрокаИнструмента, Аргументы);

	Если ТипЗнч(Результат) = Тип("Структура") И Результат.Свойство("content") Тогда
		Если Результат.content.Количество() > 0 И Результат.content[0].Свойство("text") Тогда
			Возврат Результат.content[0].text;
		КонецЕсли;
	КонецЕсли;

	Возврат Строка(Результат);

КонецФункции

