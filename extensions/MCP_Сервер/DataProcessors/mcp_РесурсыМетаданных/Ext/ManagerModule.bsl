Функция ПрочитатьРесурс(Адрес) Экспорт
	
	// Cursor URL-кодирует кириллицу: раскодируем только "хвост" после префикса
	Если Адрес = "mcp://meta/documents" Тогда
		Возврат СписокОбъектовMarkdown("Documents", Метаданные.Документы, "mcp://meta/document/");
	КонецЕсли;

	Если Адрес = "mcp://meta/accumulationregisters" Тогда
		Возврат СписокОбъектовMarkdown("AccumulationRegisters", Метаданные.РегистрыНакопления, "mcp://meta/accumulationregister/");
	КонецЕсли;

	Если Адрес = "mcp://meta/informationregisters" Тогда
		Возврат СписокОбъектовMarkdown("InformationRegisters", Метаданные.РегистрыСведений, "mcp://meta/informationregister/");
	КонецЕсли;

	Если СтрНачинаетсяС(Адрес, "mcp://meta/document/") Тогда
		Имя = Сред(Адрес, СтрДлина("mcp://meta/document/") + 1);
		Возврат ТекстСтруктуры("Documents", Имя);
	КонецЕсли;

	Если СтрНачинаетсяС(Адрес, "mcp://meta/accumulationregister/") Тогда
		Имя = Сред(Адрес, СтрДлина("mcp://meta/accumulationregister/") + 1);
		Возврат ТекстСтруктуры("AccumulationRegisters", Имя);
	КонецЕсли;

	Если СтрНачинаетсяС(Адрес, "mcp://meta/informationregister/") Тогда
		Имя = Сред(Адрес, СтрДлина("mcp://meta/informationregister/") + 1);
		Возврат ТекстСтруктуры("InformationRegisters", Имя);
	КонецЕсли;
	
	Если СтрНачинаетсяС(Адрес, "mcp://ctx/posting/") Тогда
		Имя = Сред(Адрес, СтрДлина("mcp://ctx/posting/") + 1);
		Возврат КонтекстПроведения(Имя);
	КонецЕсли;

	ВызватьИсключение "Неизвестный ресурс: " + Адрес;

КонецФункции


Функция КонтекстПроведения(ИмяДокумента) Экспорт
	
	Текст = "# Контекст для генерации проведения" + Символы.ПС;
	Текст = Текст + "Документ: **" + ИмяДокумента + "**" + Символы.ПС + Символы.ПС;
	
	Текст = Текст + "## Метаданные документа" + Символы.ПС;
	Текст = Текст + "```" + Символы.ПС;
	Текст = Текст + ТекстСтруктуры("Documents", ИмяДокумента) + Символы.ПС;
	Текст = Текст + "```" + Символы.ПС + Символы.ПС;
	
	// Ниже можно сделать маппинг "документ -> регистры", но пока захардкодим под Сделку
	Текст = Текст + "## Регистр накопления: ПозицииИнструментов" + Символы.ПС;
	Текст = Текст + "```" + Символы.ПС;
	Текст = Текст + ТекстСтруктуры("AccumulationRegisters", "ПозицииИнструментов") + Символы.ПС;
	Текст = Текст + "```" + Символы.ПС + Символы.ПС;
	
	Текст = Текст + "## Регистр накопления: ФинансовыеРезультатыПоСделкам" + Символы.ПС;
	Текст = Текст + "```" + Символы.ПС;
	Текст = Текст + ТекстСтруктуры("AccumulationRegisters", "ФинансовыеРезультатыПоСделкам") + Символы.ПС;
	Текст = Текст + "```" + Символы.ПС + Символы.ПС;
	
	Текст = Текст + "## Правила учета (важно для генерации)" + Символы.ПС;
	Текст = Текст + "- Учет количества ведется **в штуках** (ресурс Количество)." + Символы.ПС;
	Текст = Текст + "- В документе есть КоличествоЛотов и Количество; в регистры пишем **Количество**." + Символы.ПС;
	Текст = Текст + "- Если `Шорт = Истина`: допускаются отрицательные остатки. Движения по количеству/стоимости могут быть отрицательными." + Символы.ПС;
	Текст = Текст + "- Комиссия из табличной части учитывается при расчете финреза (Комиссия, ПрибыльУбыток)." + Символы.ПС;
	
	Возврат Текст;

КонецФункции

