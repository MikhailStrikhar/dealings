Процедура ДобавитьРесурсы(Ресурсы) Экспорт
	
	// Список документов
	mcp_Метаданные.ДобавитьРесурс(Ресурсы,
		"mcp://meta/documents",
		"Метаданные: Документы",
		"Список документов");

	// Конкретные документы: mcp://meta/document/<Имя>
	Для Каждого Док Из Метаданные.Документы Цикл
		URI = "mcp://meta/document/" + Док.Имя;

		mcp_Метаданные.ДобавитьРесурс(Ресурсы,
			URI,
			"Документ: " + Док.Синоним,
			"Структура документа " + Док.Имя);
	КонецЦикла;
		
	//mcp_Метаданные.ДобавитьРесурс(Ресурсы,
	//	"mcp://meta/accumulationregister/ПозицииИнструментов",
	//	"Регистр: ПозицииИнструментов",
	//	"Структура регистра накопления ПозицииИнструментов");

	//mcp_Метаданные.ДобавитьРесурс(Ресурсы,
	//	"mcp://meta/accumulationregister/ФинансовыеРезультатыПоСделкам",
	//	"Регистр: ФинансовыеРезультатыПоСделкам",
	//	"Структура регистра накопления ФинансовыеРезультатыПоСделкам");		
	
	Для Каждого РН Из Метаданные.РегистрыНакопления Цикл
		URI = "mcp://meta/AccumulationRegister/" + РН.Имя;

		mcp_Метаданные.ДобавитьРесурс(Ресурсы,
			URI,
			"Регистр накопления: " + РН.Синоним,
			"Структура регистра накопления " + РН.Имя);
	КонецЦикла;
	
	Для Каждого РС Из Метаданные.РегистрыСведений Цикл
		URI = "mcp://meta/InformationRegister/" + РС.Имя;

		mcp_Метаданные.ДобавитьРесурс(Ресурсы,
			URI,
			"Регистр сведений: " + РС.Синоним,
			"Структура регистра сведений " + РС.Имя);
	КонецЦикла;
		
	mcp_Метаданные.ДобавитьРесурс(Ресурсы,
		"mcp://ctx/posting/Сделка",
		"Контекст проведения: Сделка",
		"Документ + регистры + правила учета для генерации кода проведения");	
		
КонецПроцедуры

