// mcp_ИнструментыКод.Менеджер

Процедура ДобавитьИнструменты(Инструменты) Экспорт
	
	// Описание инструмента: получить текст общего модуля
	Описание = Новый Структура;
	Описание.Вставить("name", "get_common_module_text");
	Описание.Вставить("description", "Возвращает текст общего модуля по его имени (CommonModules).");
	
	// JSON Schema входных параметров
	Схема = Новый Структура;
	Схема.Вставить("type", "object");
	
	Свойства = Новый Структура;
	СвойствоName = Новый Структура;
	СвойствоName.Вставить("type", "string");
	СвойствоName.Вставить("description", "Имя общего модуля (точное, без учета регистра).");
	Свойства.Вставить("name", СвойствоName);
	
	Схема.Вставить("properties", Свойства);
	
	Required = Новый Массив;
	Required.Добавить("name"); 
	Схема.Вставить("required", Required);
	
	Описание.Вставить("inputSchema", Схема);
	
	// ✅ Добавляем строку в ТаблицуЗначений
	НоваяСтрока = Инструменты.Добавить();
	НоваяСтрока.Имя = Описание.name;
	НоваяСтрока.Описание = Описание.description;
	НоваяСтрока.СхемаПараметров = mcp_ОбщегоНазначения.СтруктураВJSON(Описание.inputSchema);
	
КонецПроцедуры

Функция ВыполнитьИнструмент(ИмяИнструмента, Аргументы) Экспорт
	
	Если ИмяИнструмента <> "get_common_module_text" Тогда
		ВызватьИсключение "Неизвестный инструмент: " + ИмяИнструмента;
	КонецЕсли;
	
	Если Аргументы = Неопределено Или Не Аргументы.Свойство("name") Тогда
		ВызватьИсключение "Требуется аргумент name";
	КонецЕсли;
	
	ИмяМодуля = Аргументы.name;
	
	// Находим общий модуль по имени (без учета регистра)
	Если Метаданные.ОбщиеМодули.Найти(ИмяМодуля) = Неопределено Тогда
		ВызватьИсключение "Общий модуль не найден: " + ИмяМодуля;
	КонецЕсли;
	
	ОбщийМодуль = Метаданные.ОбщиеМодули[ИмяМодуля];
	Текст = ОбщийМодуль.МодульТекст;
	
	// Возвращаем строку (сервер обернет в ответ MCP)
	Возврат Текст;
	
КонецФункции