Функция СоздатьИнструмент(UID)
	
	Отказ = Ложь;
	СоединениеTInvest = ИнтеграцияTInvestAPI.TI_СоздатьHTTPСоединение();
	Данные = ИнтеграцияTInvestAPI.TI_ОсновнаяИнформацияОбИнструменте(UID, , "INSTRUMENT_ID_TYPE_UID", , , СоединениеTInvest);
	
	Если ЗначениеЗаполнено(Данные) И Данные.Свойство("instrument") Тогда
		ИнструментОбъект = Справочники.Инструменты.СоздатьЭлемент();
		ДанныеИнструмента = Данные.instrument;
		ЗаполнитьЗначенияСвойств(ИнструментОбъект, ДанныеИнструмента);
		ИнструментОбъект.РазмерЛота = ДанныеИнструмента.lot;
		ИнструментОбъект.Наименование = ДанныеИнструмента.name;
		ИнструментОбъект.ВалютаНоминала = Справочники.Валюты.НайтиПоНаименованию(ДанныеИнструмента.currency);
		Если Не ЗначениеЗаполнено(ИнструментОбъект.ВалютаНоминала) И ЗначениеЗаполнено(ДанныеИнструмента.currency) Тогда
			ОбщегоНазначения.СообщитьПользователю("Не найдена валюта " + ДанныеИнструмента.currency, , , , Отказ);
		КонецЕсли;
		Если Не Отказ Тогда
			ИнструментОбъект.Записать();
			ОбщегоНазначения.СообщитьПользователю("Записан новый инструмент " + ИнструментОбъект, ИнструментОбъект.Ссылка);
			
			Возврат ИнструментОбъект.Ссылка;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Неопределено;

КонецФункции // СоздатьИнструмент()

#КонецОбласти

