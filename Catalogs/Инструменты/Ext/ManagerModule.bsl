Функция ПолучитьИнструментПоУИД(UID) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Инструменты.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Инструменты КАК Инструменты
		|ГДЕ
		|	Инструменты.UID = &UID
		|	И не Инструменты.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("UID", UID);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	Иначе
		НовыйИнструмент = СоздатьИнструмент(UID);
		Возврат НовыйИнструмент;
	КонецЕсли;

КонецФункции // ПолучитьИнструментПоУИД()

